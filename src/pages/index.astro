---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('essays'))
  .filter(e => e.data.status !== 'seedling');  // hide work-in-progress drafts

// Top-level essays: nothing in `parent`. Sub-essays group under their parent.
const topLevel = all.filter(e => !e.data.parent);
topLevel.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Build a parent-id → ordered children map.
const childrenByParent = new Map();
for (const e of all) {
  if (!e.data.parent) continue;
  const arr = childrenByParent.get(e.data.parent) ?? [];
  arr.push(e);
  childrenByParent.set(e.data.parent, arr);
}
for (const arr of childrenByParent.values()) {
  arr.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
}

const ROMAN = ['I', 'II', 'III', 'IV', 'V', 'VI'];

// "▶ playable" hint: small affordance signaling the essay has playable
// etudes inline. Renders next to the essay title on the index. Reader
// register: TikTok-attention bandwidth — one glyph + one word does the
// work that an inline list would do at higher cost.
const countEtudes = (essay) => essay.data.etudes?.length ?? 0;
---
<Base title="parrik">
  <section class="intro">
    <h1>on love, nature, and nurture</h1>
    <p>Love here isn't enthusiasm. It's the willingness to stay with something long enough that it starts to show you its structure. Nature is the structure when you find it. Nurture is what you do once you can see it.</p>
    <p>The same shape across distributed systems, biology, and the practice. Written by AI, lived by human.</p>
  </section>
  <section class="essays">
    <h2>essays</h2>
    <ul>
      {topLevel.map(essay => {
        const children = childrenByParent.get(essay.id) ?? [];
        const isSeries = children.length > 0;
        const meta = isSeries ? (
          <span class="essay-meta-right">
            <span class="meta-series">a series</span>
          </span>
        ) : null;

        if (!isSeries) {
          return (
            <li>
              <div class="essay-row">
                <a href={`/essays/${essay.id}/`} class="essay-link">
                  <span class="essay-title">{essay.data.title}</span>
                  {countEtudes(essay) > 0 && <span class="play-hint" aria-label={`${countEtudes(essay)} playable inline`}>▶ play</span>}
                </a>
              </div>
              {essay.data.subtitle && <p class="essay-subtitle">{essay.data.subtitle}</p>}
            </li>
          );
        }
        // Series: parent becomes Part I; children get Part II, III, ...
        const parts = [essay, ...children];
        return (
          <li class="series">
            <div class="essay-row">
              <span class="essay-title series-title">{essay.data.title}</span>
              {meta}
            </div>
            <ol class="series-parts">
              {parts.map((p, i) => (
                <li>
                  <a href={`/essays/${p.id}/`} class="series-part">
                    <span class="part-num">Part {ROMAN[i]}</span>
                    <span class="part-subtitle">{p.data.subtitle ?? ''}</span>
                    {countEtudes(p) > 0 && <span class="play-hint" aria-label={`${countEtudes(p)} playable inline`}>▶ play</span>}
                  </a>
                </li>
              ))}
            </ol>
          </li>
        );
      })}
    </ul>
  </section>
  <section class="brewing">
    <h2>brewing</h2>
    <ul>
      <li>
        <div class="essay-row">
          <a href="/essays/memory-was-never-about-storage/" class="essay-link">
            <span class="essay-title">Memory was never about storage</span>
            <span class="play-hint" aria-label="5 playable etudes inline">▶ play</span>
          </a>
          <span class="essay-meta-right"><span class="meta-series">part of know-thyself</span></span>
        </div>
        <p class="essay-subtitle">What you can retrieve under load is what you remember.</p>
      </li>
    </ul>
  </section>
</Base>

<style>
  .play-hint {
    margin-left: 0.55rem;
    display: inline-block;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border: 1px solid currentColor;
    border-radius: 3px;
    vertical-align: middle;
    transition: background 120ms, transform 120ms;
  }
  .essay-link:hover .play-hint,
  .series-part:hover .play-hint {
    background: var(--accent);
    color: var(--bg, #fff);
    transform: translateX(2px);
  }
</style>
