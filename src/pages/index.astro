---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('essays');

// Every essay is a work-in-progress at some stage of development —
// seedling / tending / evergreen are stages of the same artifact, not
// separate hierarchies. Surface them in one unified list. The
// per-essay status lives in the MetadataStripe on each page, where
// the reader can see *Planted ... · seedling* or *... · tending* and
// know what they are reading. The homepage's job is to show the
// structure of the body of work.
const topLevel = all.filter(e => !e.data.parent && !e.data.track);
topLevel.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Build a parent-id → ordered children map. Children include all
// statuses — a series has all its parts visible, in order, even when
// the later parts are still seedling.
const childrenByParent = new Map();
for (const e of all) {
  if (!e.data.parent) continue;
  const arr = childrenByParent.get(e.data.parent) ?? [];
  arr.push(e);
  childrenByParent.set(e.data.parent, arr);
}
for (const arr of childrenByParent.values()) {
  arr.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
}

const ROMAN = ['I', 'II', 'III', 'IV', 'V', 'VI'];

// "▶ playable" hint: small affordance signaling the essay has playable
// etudes inline. Renders next to the essay title on the index. Reader
// register: TikTok-attention bandwidth — one glyph + one word does the
// work that an inline list would do at higher cost.
const countEtudes = (essay) => essay.data.etudes?.length ?? 0;
---
<Base title="parrik">
  <section class="intro">
    <h1>on love, nature, and nurture</h1>
    <p>Love here isn't enthusiasm. It's the willingness to stay with something long enough that it starts to show you its structure. Nature is the structure when you find it. Nurture is what you do once you can see it. The same shape across distributed systems, biology, and the practice.</p>
    <p class="byline">Twelve-plus years on distributed-systems infrastructure — AWS, Cruise, Bloomberg, Microsoft.</p>
  </section>
  <section class="essays">
    <h2>puzzle-shape problems</h2>
    <ul>
      {topLevel.map(essay => {
        const children = childrenByParent.get(essay.id) ?? [];
        const isSeries = children.length > 0;
        const meta = isSeries ? (
          <span class="essay-meta-right">
            <span class="meta-series">a series</span>
          </span>
        ) : null;

        if (!isSeries) {
          return (
            <li>
              <div class="essay-row">
                <a href={`/essays/${essay.id}/`} class="essay-link">
                  <span class="essay-title">{essay.data.title}</span>
                  {countEtudes(essay) > 0 && <span class="play-hint" aria-label={`${countEtudes(essay)} playable inline`}>▶ play</span>}
                </a>
              </div>
              {(essay.data.relief || essay.data.subtitle) && <p class="essay-subtitle">{essay.data.relief ?? essay.data.subtitle}</p>}
            </li>
          );
        }
        // Series: parent becomes Part I; children get Part II, III, ...
        // Series header uses `seriesName` if set, else falls back to the
        // parent's title — lets each part have its own claim-shaped title
        // while the series keeps an umbrella name.
        const parts = [essay, ...children];
        const seriesLabel = essay.data.seriesName ?? essay.data.title;
        return (
          <li class="series">
            <div class="essay-row">
              <span class="essay-title series-title">{seriesLabel}</span>
              {meta}
            </div>
            <ol class="series-parts">
              {parts.map((p, i) => {
                const muted = i > 0;
                if (!muted) {
                  return (
                    <li>
                      <a href={`/essays/${p.id}/`} class="series-part">
                        <span class="part-num">Part {ROMAN[i]}</span>
                        <span class="part-body">
                          <span class="part-name">
                            {p.data.title}
                            {countEtudes(p) > 0 && <span class="play-hint" aria-label={`${countEtudes(p)} playable inline`}>▶ play</span>}
                          </span>
                          {(p.data.relief || p.data.subtitle) && <span class="part-description">{p.data.relief ?? p.data.subtitle}</span>}
                        </span>
                      </a>
                    </li>
                  );
                }
                const desc = p.data.relief ?? p.data.subtitle;
                return (
                  <li>
                    <div class="series-part series-part-muted" aria-disabled="true">
                      <span class="part-num">Part {ROMAN[i]}</span>
                      <span class="part-body">
                        <span class="part-name">{p.data.title}</span>
                        {desc ? (
                          <span class="part-description">
                            {desc}{' '}<a href={`/essays/${p.id}/`} class="read-draft">read draft →</a>
                          </span>
                        ) : (
                          <a href={`/essays/${p.id}/`} class="read-draft">read draft →</a>
                        )}
                      </span>
                    </div>
                  </li>
                );
              })}
            </ol>
          </li>
        );
      })}
    </ul>
  </section>
  <div slot="footer-extra" class="maxims-grid">
    <div class="maxim-name">know thyself</div>
    <div class="maxim-name">reveal thyself</div>
  </div>
</Base>

<style>
  .play-hint {
    margin-left: 0.5rem;
    display: inline-block;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 0.72rem;
    color: var(--muted);
    font-weight: 500;
    vertical-align: middle;
    opacity: 0.7;
    transition: color 140ms, opacity 140ms;
  }
  .essay-link:hover .play-hint,
  .series-part:hover .play-hint {
    color: var(--accent);
    opacity: 1;
  }
</style>
