---
import Base from '../../../layouts/Base.astro';

const etudes = [
  { name: 'Token Budget', href: '/etudes/know-thyself/token-budget/', desc: 'Slide the graph size; watch the paste break.' },
  { name: 'Two Queries', href: '/etudes/know-thyself/two-queries/', desc: 'Type like a human, then like an agent.' },
  { name: 'Flat vs Typed', href: '/etudes/know-thyself/flat-vs-typed/', desc: 'Same data, two memories.' },
  { name: 'Six Restatements', href: '/etudes/know-thyself/six-restatements/', desc: 'One claim said six ways is one derivation, not six.' },
  { name: 'Attribution ≠ Confidence', href: '/etudes/know-thyself/attribution-confidence/', desc: 'Drill the rule across six scenarios.' },
];
---
<Base title="Know Thyself etudes">
  <article class="etude-page">
    <header class="etude-head">
      <p class="etude-kicker">Etudes · Know Thyself</p>
      <h1 class="etude-title">Know Thyself</h1>
      <p class="etude-relief">Five studies on memory shape, attribution, and retrieval over typed personal graphs.</p>
      <nav class="etude-nav">
        <a href="/essays/know-thyself/">← essay (Pt I)</a>
        <span class="etude-nav-sep">·</span>
        <a href="/essays/know-thyself-search/">essay (Pt II)</a>
        <span class="etude-nav-sep">·</span>
        <a href="/etudes/">all etudes</a>
      </nav>
    </header>

    <ul class="etude-list">
      {etudes.map(e => (
        <li>
          <a href={e.href} class="etude-link">
            <span class="etude-name">{e.name}</span>
            <span class="etude-sep"> &mdash; </span>
            <span class="etude-desc">{e.desc}</span>
          </a>
        </li>
      ))}
    </ul>
  </article>
</Base>

<style>
  .etude-page { max-width: 38rem; margin: 0 auto; padding: 0; }
  .etude-head { margin-bottom: 2rem; }
  .etude-kicker {
    font-family: var(--sans);
    font-size: var(--label-size);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin: 0 0 0.6rem;
  }
  .etude-title {
    font-family: var(--serif-display);
    font-size: 2.25rem;
    line-height: 1.15;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .etude-relief {
    font-family: var(--serif);
    font-style: italic;
    color: var(--muted);
    font-size: 1.05rem;
    margin: 0 0 1rem;
    line-height: 1.45;
  }
  .etude-nav { font-family: var(--sans); font-size: 0.85rem; color: var(--muted); }
  .etude-nav a { color: var(--muted); text-decoration: none; }
  .etude-nav a:hover { color: var(--accent); }
  .etude-nav-sep { margin: 0 0.5rem; opacity: 0.5; }

  .etude-list { list-style: none; padding: 0; margin: 0; }
  .etude-list li { padding: 0.7rem 0; border-bottom: 1px solid var(--line); }
  .etude-list li:last-child { border-bottom: none; }
  .etude-link { display: block; text-decoration: none; color: var(--text); line-height: 1.45; }
  .etude-name { font-weight: 600; }
  .etude-link:hover .etude-name { color: var(--accent); text-decoration: underline; }
  .etude-sep { color: var(--muted); }
  .etude-desc { color: var(--muted); }

  @media (max-width: 32rem) {
    .etude-title { font-size: 1.85rem; }
    .etude-sep { display: none; }
    .etude-desc { display: block; font-size: 0.92rem; margin-top: 0.15rem; }
  }
</style>
