---
import Base from '../../../layouts/Base.astro';
const title = 'Flat vs Typed';
const subtitle = 'Same data. Two memories. Watch where the list breaks.';
---
<Base title={title} description={subtitle}>
  <article class="etude-page">
    <header class="etude-head">
      <p class="etude-kicker">Etude · Know Thyself · Pt I</p>
      <h1 class="etude-title">{title}</h1>
      <p class="etude-relief">{subtitle}</p>
      <nav class="etude-nav">
        <a href="/etudes/know-thyself/">← know thyself etudes</a>
        <span class="etude-nav-sep">·</span>
        <a href="/puzzles/know-thyself/">puzzle</a>
      </nav>
    </header>

    <section class="etude-intro">
      <p>A flat list cannot tell <em>I said this five times</em> from <em>five independent observations</em>. The typed-graph schema — nodes plus provenance — makes the distinction structurally. Eight facts about Alex, both shapes.</p>
    </section>

    <details class="etude-data-box">
      <summary>The 8 facts both memories receive</summary>
      <ol id="facts-list" class="etude-facts"></ol>
    </details>

    <div class="etude-query-row">
      <input id="query" type="text" value="What's true about Alex?" aria-label="Query" />
      <button type="button" id="ask" class="etude-ask-btn">Ask</button>
    </div>

    <div class="etude-stage etude-columns">
      <section class="etude-card etude-col-flat" aria-labelledby="flat-h">
        <p class="etude-step">Flat</p>
        <h2 id="flat-h" class="etude-card-title">Flat-list memory</h2>
        <div class="etude-badge-row">
          <span class="etude-badge">facts: <b id="flat-count">8</b></span>
          <span class="etude-badge etude-badge-warn">conflict mentions: <b id="flat-conflict">0</b></span>
        </div>
        <div id="flat-out" class="etude-out" aria-live="polite"></div>
      </section>

      <section class="etude-card etude-col-graph" aria-labelledby="graph-h">
        <p class="etude-step">Typed</p>
        <h2 id="graph-h" class="etude-card-title">Typed-graph memory</h2>
        <div class="etude-badge-row">
          <span class="etude-badge">nodes: <b id="graph-nodes">0</b></span>
          <span class="etude-badge etude-badge-ok">derivations: <b id="graph-derivs">0</b></span>
        </div>
        <div id="graph-out" class="etude-out" aria-live="polite"></div>
      </section>
    </div>

    <div class="etude-controls">
      <button type="button" id="add-restate" class="etude-ctl-btn">+ Add another self-restatement</button>
      <button type="button" id="reset" class="etude-ctl-btn etude-ctl-btn-quiet">Reset</button>
    </div>

    <footer class="etude-coda">
      <p><strong>Repetition isn't corroboration.</strong> The flat list cannot tell the difference. The typed graph can. The shape, not the substrate, is what carries the distinction.</p>
    </footer>
  </article>
</Base>

<script is:inline>
  const SEED = [
    { id: 1,  text: "Alex mentioned avoiding conflict",       src: "Conv #1, Mar 4",   kind: "self-restate", claim: "avoids-conflict" },
    { id: 2,  text: "Alex mentioned avoiding conflict",       src: "Conv #5, Mar 18",  kind: "self-restate", claim: "avoids-conflict" },
    { id: 3,  text: "Alex mentioned avoiding conflict",       src: "Conv #11, Apr 22", kind: "self-restate", claim: "avoids-conflict" },
    { id: 4,  text: "Alex restated avoiding conflict",        src: "Conv #14, May 7",  kind: "self-restate", claim: "avoids-conflict" },
    { id: 5,  text: "Alex mentioned avoiding conflict",       src: "Conv #19, May 22", kind: "self-restate", claim: "avoids-conflict" },
    { id: 6,  text: "Editorial director's review: 'Alex avoids conflict'", src: "Year-end review, Apr", kind: "external-obs", claim: "avoids-conflict" },
    { id: 7,  text: "Alex mentioned thriving when working solo", src: "Conv #2, Mar 7",   kind: "self-restate", claim: "thrives-independence" },
    { id: 8,  text: "Alex shepherded a solo 6-month book to print end-to-end", src: "Verified, Apr 30", kind: "grounded-episode", claim: "thrives-independence" },
  ];

  let facts = SEED.slice();
  let extraCounter = 0;

  function renderFacts() {
    const ol = document.getElementById('facts-list');
    ol.innerHTML = facts.map(f =>
      `<li class="etude-fact etude-fact-${f.kind}" data-id="${f.id}"><span class="etude-fact-text">${f.text}</span> <span class="etude-fact-src">(${f.src})</span></li>`
    ).join('');
  }

  function tickBadge(el, target) {
    const cur = parseInt(el.textContent || '0', 10);
    if (cur === target) return;
    const dir = target > cur ? 1 : -1;
    let v = cur;
    el.classList.add('etude-badge-flash');
    const step = () => {
      v += dir;
      el.textContent = v;
      if (v !== target) requestAnimationFrame(step);
      else setTimeout(() => el.classList.remove('etude-badge-flash'), 250);
    };
    requestAnimationFrame(step);
  }

  function conf(n) {
    if (n >= 6) return { word: 'very high', cls: 'etude-conf-vhigh' };
    if (n >= 4) return { word: 'high',      cls: 'etude-conf-high'  };
    if (n >= 2) return { word: 'medium',    cls: 'etude-conf-med'   };
    return            { word: 'low',        cls: 'etude-conf-low'   };
  }

  function flatAnswer() {
    const groups = {};
    facts.forEach(f => { groups[f.claim] = (groups[f.claim] || 0) + 1; });
    const cN = groups['avoids-conflict'] || 0, iN = groups['thrives-independence'] || 0;
    const cC = conf(cN), cI = conf(iN);
    tickBadge(document.getElementById('flat-count'), facts.length);
    tickBadge(document.getElementById('flat-conflict'), cN);
    return `
      <p><strong>Alex avoids conflict.</strong> <span class="etude-conf ${cC.cls}">${cC.word} confidence — corroborated ${cN} times.</span></p>
      <p><strong>Alex thrives on independence.</strong> <span class="etude-conf ${cI.cls}">${cI.word} confidence — mentioned ${iN} time${iN===1?'':'s'}.</span></p>
      <p class="etude-answer-detail">Repetition compresses into confidence. More mentions → stronger claim.</p>`;
  }

  function deriv(c) { return (c.self > 0 ? 1 : 0) + c.ext + c.grounded; }

  function graphLine(label, c) {
    const d = deriv(c), bits = [];
    if (c.self     > 0) bits.push(`${c.self} self-restatement${c.self===1?'':'s'} → 1 self-attribution`);
    if (c.ext      > 0) bits.push(`${c.ext} external observer`);
    if (c.grounded > 0) bits.push(`${c.grounded} grounded episode`);
    const tag = c.grounded > 0 ? '<span class="etude-tag etude-tag-ok">grounded</span>'
              : c.ext > 0      ? '<span class="etude-tag etude-tag-warn">tentative-supported</span>'
              :                  '<span class="etude-tag etude-tag-low">tentative</span>';
    return `<li><strong>Alex — '${label}'</strong>: ${bits.join(', ')}. <em>Net: ${d} derivation${d===1?'':'s'}.</em> ${tag}</li>`;
  }

  function graphAnswer() {
    const claims = {};
    facts.forEach(f => {
      const c = claims[f.claim] = claims[f.claim] || { self: 0, ext: 0, grounded: 0 };
      if (f.kind === 'self-restate')     c.self += 1;
      if (f.kind === 'external-obs')     c.ext  += 1;
      if (f.kind === 'grounded-episode') c.grounded += 1;
    });
    const cf = claims['avoids-conflict']      || { self: 0, ext: 0, grounded: 0 };
    const ip = claims['thrives-independence'] || { self: 0, ext: 0, grounded: 0 };
    tickBadge(document.getElementById('graph-nodes'),  Object.keys(claims).length);
    tickBadge(document.getElementById('graph-derivs'), deriv(cf) + deriv(ip));
    return `
      <ul class="etude-provenance">${graphLine('avoids conflict', cf)}${graphLine('thrives on independence', ip)}</ul>
      <p class="etude-answer-detail">Five surface restatements collapse to one self-attribution. Counts don't migrate into confidence on their own — only typed sources do.</p>`;
  }

  function ask() {
    const f = document.getElementById('flat-out');
    const g = document.getElementById('graph-out');
    f.classList.remove('etude-flash'); g.classList.remove('etude-flash');
    void f.offsetWidth; void g.offsetWidth;
    f.innerHTML = flatAnswer();
    g.innerHTML = graphAnswer();
    f.classList.add('etude-flash'); g.classList.add('etude-flash');
  }

  function addRestate() {
    extraCounter += 1;
    const nextId = facts.length + 1;
    facts.push({
      id: nextId,
      text: "Alex mentioned avoiding conflict",
      src: `Conv #${20 + extraCounter}, added`,
      kind: "self-restate",
      claim: "avoids-conflict",
    });
    renderFacts();
    const ol = document.getElementById('facts-list');
    const last = ol.lastElementChild;
    if (last) { last.classList.add('etude-fact-new'); setTimeout(() => last.classList.remove('etude-fact-new'), 600); }
    ask();
  }

  function reset() {
    facts = SEED.slice();
    extraCounter = 0;
    renderFacts();
    document.getElementById('flat-out').innerHTML  = '';
    document.getElementById('graph-out').innerHTML = '';
    document.getElementById('flat-count').textContent    = facts.length;
    document.getElementById('flat-conflict').textContent = '0';
    document.getElementById('graph-nodes').textContent   = '0';
    document.getElementById('graph-derivs').textContent  = '0';
  }

  document.getElementById('ask').addEventListener('click', ask);
  document.getElementById('add-restate').addEventListener('click', addRestate);
  document.getElementById('reset').addEventListener('click', (e) => { e.preventDefault(); reset(); });

  renderFacts();
  ask();
</script>

<style is:global>
  /* === etude page chrome === */
  .etude-page {
    max-width: 44rem;
    margin: 0 auto;
    padding: 0;
  }
  .etude-head {
    margin-bottom: 2rem;
  }
  .etude-kicker {
    font-family: var(--sans);
    font-size: var(--label-size);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin: 0 0 0.6rem;
  }
  .etude-title {
    font-family: var(--serif-display);
    font-size: 2.25rem;
    line-height: 1.15;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .etude-relief {
    font-family: var(--serif);
    font-style: italic;
    color: var(--muted);
    font-size: 1.05rem;
    margin: 0 0 1rem;
    line-height: 1.45;
  }
  .etude-nav {
    font-family: var(--sans);
    font-size: 0.85rem;
    color: var(--muted);
  }
  .etude-nav a { color: var(--muted); text-decoration: none; }
  .etude-nav a:hover { color: var(--accent); }
  .etude-nav-sep { margin: 0 0.5rem; opacity: 0.5; }

  .etude-intro {
    margin: 0 0 1.5rem;
  }
  .etude-intro p {
    margin: 0 0 0.85rem;
    line-height: 1.6;
  }

  /* === data box (the 8 facts) === */
  .etude-data-box {
    margin: 0 0 1.25rem;
  }
  .etude-data-box summary {
    cursor: pointer;
    color: var(--muted);
    font-family: var(--sans);
    font-size: 0.88rem;
    padding: 0.4rem 0;
    transition: color 180ms ease;
  }
  .etude-data-box summary:hover { color: var(--accent); }
  .etude-facts {
    margin: 0.6rem 0 0;
    padding: 1rem 1.25rem 1rem 2.25rem;
    background: var(--bg-soft);
    border-radius: 10px;
    line-height: 1.55;
    font-size: 0.92rem;
  }
  .etude-fact {
    margin: 0.3rem 0;
    transition: background 300ms;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }
  .etude-fact-src { color: var(--muted); font-size: 0.85rem; }
  .etude-fact-self-restate     { border-left: 2px solid rgba(138, 52, 32, 0.35); padding-left: 0.55rem; }
  .etude-fact-external-obs     { border-left: 2px solid #c98b1a; padding-left: 0.55rem; }
  .etude-fact-grounded-episode { border-left: 2px solid #2f8f4e; padding-left: 0.55rem; }
  .etude-fact-new { background: rgba(255, 220, 90, 0.45); }

  /* === query row === */
  .etude-query-row {
    display: flex;
    gap: 0.6rem;
    margin: 0 0 1.5rem;
  }
  .etude-query-row input {
    flex: 1;
    font: inherit;
    font-size: 0.95rem;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg);
    color: var(--text);
    transition: border-color 180ms ease;
  }
  .etude-query-row input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .etude-ask-btn {
    appearance: none;
    -webkit-appearance: none;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.65rem 1.2rem;
    border: none;
    background: var(--text);
    color: var(--bg);
    border-radius: 999px;
    cursor: pointer;
    transition: background 180ms ease, transform 120ms ease;
  }
  .etude-ask-btn:hover { background: var(--accent); }
  .etude-ask-btn:active { transform: scale(0.97); }
  .etude-ask-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  /* === stage / two-column comparison === */
  .etude-stage {
    min-height: 18rem;
  }
  .etude-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0 0 1rem;
  }

  /* === card surfaces === */
  .etude-card {
    background: var(--bg-soft);
    border-radius: 12px;
    padding: 1.5rem 1.5rem 1.25rem;
  }
  .etude-step {
    font-family: var(--sans);
    font-size: var(--label-size);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin: 0 0 0.6rem;
  }
  .etude-card-title {
    font-family: var(--serif-display);
    font-size: 1.25rem;
    line-height: 1.25;
    margin: 0 0 0.85rem;
    letter-spacing: -0.005em;
    color: var(--text);
  }

  /* === badges === */
  .etude-badge-row {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.85rem;
  }
  .etude-badge {
    font-family: var(--sans);
    font-size: 0.78rem;
    padding: 0.2rem 0.6rem;
    background: var(--bg);
    border-radius: 999px;
    color: var(--muted);
    transition: transform 180ms, background 180ms;
  }
  .etude-badge b { color: var(--text); }
  .etude-badge-warn { background: rgba(201, 139, 26, 0.15); }
  .etude-badge-ok   { background: rgba(47, 143, 78, 0.15); }
  .etude-badge-flash { transform: scale(1.12); background: rgba(255, 220, 90, 0.55); }

  /* === answer output === */
  .etude-out { font-size: 0.94rem; line-height: 1.55; color: var(--text); }
  .etude-out p { margin: 0.5rem 0; }
  .etude-out.etude-flash { animation: etude-flash 320ms ease-out; }
  @keyframes etude-flash {
    from { background: rgba(255, 220, 90, 0.35); }
    to   { background: transparent; }
  }
  .etude-conf { font-style: italic; font-size: 0.88rem; margin-left: 0.3rem; }
  .etude-conf-vhigh { color: #b8323b; font-weight: 600; }
  .etude-conf-high  { color: #c98b1a; }
  .etude-conf-med, .etude-conf-low { color: var(--muted); }
  .etude-provenance { padding-left: 1.1rem; margin: 0.3rem 0; }
  .etude-provenance li { margin: 0.5rem 0; }
  .etude-tag {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    margin-left: 0.25rem;
    vertical-align: 1px;
  }
  .etude-tag-ok   { background: rgba(47, 143, 78, 0.18); color: #2f8f4e; }
  .etude-tag-warn { background: rgba(201, 139, 26, 0.18); color: #a87217; }
  .etude-tag-low  { background: rgba(0,0,0,0.08); color: var(--muted); }
  .etude-answer-detail { color: var(--muted); font-size: 0.9rem; }

  /* === controls === */
  .etude-controls {
    display: flex;
    gap: 0.6rem;
    margin: 1.25rem 0 0;
    flex-wrap: wrap;
  }
  .etude-ctl-btn {
    appearance: none;
    -webkit-appearance: none;
    font-family: var(--sans);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.55rem 1rem;
    border: 1px solid var(--line);
    background: var(--bg);
    color: var(--text);
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease, color 180ms ease, transform 120ms ease;
  }
  .etude-ctl-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .etude-ctl-btn:active { transform: scale(0.97); }
  .etude-ctl-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .etude-ctl-btn-quiet { color: var(--muted); }

  /* === coda === */
  .etude-coda {
    margin: 2.5rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }
  .etude-coda p {
    color: var(--muted);
    font-style: italic;
    line-height: 1.6;
    margin: 0;
  }
  .etude-coda strong { color: var(--text); font-style: normal; }

  /* === mobile === */
  @media (max-width: 32rem) {
    .etude-title { font-size: 1.85rem; }
    .etude-columns { grid-template-columns: 1fr; gap: 0.85rem; }
    .etude-card { padding: 1.15rem 1.1rem 1rem; border-radius: 10px; }
    .etude-card-title { font-size: 1.15rem; }
    .etude-query-row { flex-direction: column; }
    .etude-ask-btn { width: 100%; }
  }
</style>
