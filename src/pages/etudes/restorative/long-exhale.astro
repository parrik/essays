---
import Base from '../../../layouts/Base.astro';
const title = 'Long Exhale';
const subtitle = 'Two minutes. Long exhale. Read the essay through your own parasympathetic.';
---
<Base title={title} description={subtitle}>
  <article class="etude-page">
    <header class="etude-head">
      <p class="etude-kicker">Etude · Restorative</p>
      <h1 class="etude-title">{title}</h1>
      <p class="etude-relief">{subtitle}</p>
      <nav class="etude-nav">
        <a href="/etudes/restorative/">← restorative etudes</a>
        <span class="etude-nav-sep">·</span>
        <a href="/puzzles/the-partition-problem/">puzzle</a>
      </nav>
    </header>

    <section class="etude-intro">
      <p>Inhale four. Exhale eight. The exhale is twice the inhale because the vagus nerve listens to that ratio — long exhales signal the parasympathetic branch to come online. Pranayama is the body's interface to the autonomic nervous system. Two minutes is enough to feel it.</p>
    </section>

    <div class="breath-stage" id="stage">
      <div class="breath-circle" id="circle">
        <span class="breath-cue" id="cue">begin</span>
      </div>
    </div>

    <div class="etude-card breath-meta-card" aria-live="polite">
      <div class="meta-row"><span class="meta-label">Cycles</span><span class="meta-val"><span id="cycles">0</span> / 10</span></div>
      <div class="meta-row"><span class="meta-label">Time</span><span class="meta-val"><span id="elapsed">0:00</span> / 2:00</span></div>
      <div class="progress"><div class="progress-fill" id="progress"></div></div>
    </div>

    <div class="controls">
      <button type="button" id="start" class="etude-next">Start</button>
      <button type="button" id="stop" class="etude-quiet">Stop</button>
      <button type="button" id="sample" class="etude-quiet etude-quiet-ghost">Just one cycle (12s)</button>
    </div>

    <div id="result" class="result" aria-live="polite"></div>

    <footer class="etude-coda">
      <p>The vagal-tone literature names this directly: long exhales activate the parasympathetic branch via the vagus nerve. Whether you read the rest of the essay or not, you've already received its first claim through your own physiology.</p>
    </footer>
  </article>
</Base>

<script is:inline>
  (function () {
    const $ = (id) => document.getElementById(id);
    const circle = $('circle'), cue = $('cue'), cyclesEl = $('cycles'),
          elapsedEl = $('elapsed'), progressEl = $('progress'), resultEl = $('result'),
          startBtn = $('start'), stopBtn = $('stop'), sampleBtn = $('sample');
    const INHALE_MS = 4000, EXHALE_MS = 8000, CYCLE_MS = INHALE_MS + EXHALE_MS;
    const TOTAL_CYCLES = 10, TOTAL_MS = CYCLE_MS * TOTAL_CYCLES;
    let running = false, startTs = 0, timers = [], rafId = null, mode = 'full', audioCtx = null;

    const fmt = (ms) => {
      const s = Math.floor(ms / 1000), m = Math.floor(s / 60), r = s % 60;
      return m + ':' + (r < 10 ? '0' : '') + r;
    };

    function tick(freq) {
      try {
        if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const o = audioCtx.createOscillator(), g = audioCtx.createGain();
        o.frequency.value = freq; o.type = 'sine'; g.gain.value = 0;
        o.connect(g); g.connect(audioCtx.destination);
        const now = audioCtx.currentTime;
        g.gain.linearRampToValueAtTime(0.04, now + 0.02);
        g.gain.linearRampToValueAtTime(0.0, now + 0.18);
        o.start(now); o.stop(now + 0.2);
      } catch (_) {}
    }

    function setPhase(phase) {
      const dur = phase === 'in' ? INHALE_MS : EXHALE_MS;
      circle.style.transition = 'transform ' + (dur / 1000) + 's cubic-bezier(0.4,0,0.2,1)';
      circle.classList.remove('inhale', 'exhale');
      circle.classList.add(phase === 'in' ? 'inhale' : 'exhale');
      cue.textContent = phase === 'in' ? 'in (4)' : 'out (8)';
      tick(phase === 'in' ? 330 : 220);
    }

    function loop() {
      if (!running) return;
      const elapsed = performance.now() - startTs;
      const limit = mode === 'sample' ? CYCLE_MS : TOTAL_MS;
      cyclesEl.textContent = Math.min(Math.floor(elapsed / CYCLE_MS), TOTAL_CYCLES);
      elapsedEl.textContent = fmt(Math.min(elapsed, TOTAL_MS));
      progressEl.style.width = Math.min(100, (elapsed / TOTAL_MS) * 100) + '%';
      if (elapsed >= limit) return finish();
      rafId = requestAnimationFrame(loop);
    }

    function schedulePhases(limit) {
      setPhase('in');
      for (let t = 0; t < limit; t += CYCLE_MS) {
        if (t + INHALE_MS < limit) timers.push(setTimeout(() => running && setPhase('out'), t + INHALE_MS));
        if (t + CYCLE_MS < limit) timers.push(setTimeout(() => running && setPhase('in'), t + CYCLE_MS));
      }
    }

    function clearPhases() { timers.forEach(clearTimeout); timers = []; }

    function start(which) {
      if (running) return;
      mode = which; running = true; resultEl.innerHTML = '';
      startTs = performance.now();
      schedulePhases(mode === 'sample' ? CYCLE_MS : TOTAL_MS);
      rafId = requestAnimationFrame(loop);
      startBtn.disabled = true; sampleBtn.disabled = true;
    }

    function stop() {
      if (!running) return;
      running = false; clearPhases();
      if (rafId) cancelAnimationFrame(rafId);
      circle.style.transition = 'transform 1.2s ease';
      circle.classList.remove('inhale', 'exhale');
      cue.textContent = 'paused';
      startBtn.disabled = false; sampleBtn.disabled = false;
    }

    function finish() {
      running = false; clearPhases();
      if (rafId) cancelAnimationFrame(rafId);
      circle.style.transition = 'transform 2s ease';
      circle.classList.remove('inhale', 'exhale');
      cue.textContent = 'rest';
      progressEl.style.width = '100%';
      startBtn.disabled = false; sampleBtn.disabled = false;
      if (mode === 'full') {
        cyclesEl.textContent = TOTAL_CYCLES; elapsedEl.textContent = '2:00';
        resultEl.innerHTML = '<p class="result-headline">10 long exhales.</p><p class="result-body">The vagus nerve has been gently keyed for 2 minutes. Notice your shoulders, your jaw, the back of your neck.</p>';
      } else {
        resultEl.innerHTML = '<p class="result-headline">One cycle.</p><p class="result-body">A small sample. The full two minutes is where the parasympathetic settles in — when you have a moment, come back.</p>';
      }
    }

    startBtn.addEventListener('click', () => start('full'));
    sampleBtn.addEventListener('click', () => start('sample'));
    stopBtn.addEventListener('click', stop);
  })();
</script>

<style is:global>
  /* === etude page chrome === */
  .etude-page {
    max-width: 38rem;
    margin: 0 auto;
    padding: 0;
  }
  .etude-head {
    margin-bottom: 2rem;
  }
  .etude-kicker {
    font-family: var(--sans);
    font-size: var(--label-size);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin: 0 0 0.6rem;
  }
  .etude-title {
    font-family: var(--serif-display);
    font-size: 2.25rem;
    line-height: 1.15;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .etude-relief {
    font-family: var(--serif);
    font-style: italic;
    color: var(--muted);
    font-size: 1.05rem;
    margin: 0 0 1rem;
    line-height: 1.45;
  }
  .etude-nav {
    font-family: var(--sans);
    font-size: 0.85rem;
    color: var(--muted);
  }
  .etude-nav a { color: var(--muted); text-decoration: none; }
  .etude-nav a:hover { color: var(--accent); }
  .etude-nav-sep { margin: 0 0.5rem; opacity: 0.5; }

  .etude-intro {
    margin: 0 0 1.5rem;
  }
  .etude-intro p {
    margin: 0 0 0.85rem;
    line-height: 1.6;
  }

  /* === breath stage: generous, calm, no card border === */
  .breath-stage {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 22rem;
    margin: 2.5rem 0 2rem;
    background: var(--bg-soft);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }
  .breath-circle {
    width: 7.5rem;
    height: 7.5rem;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, rgba(184, 216, 212, 0.95), rgba(111, 168, 164, 0.85) 70%, rgba(77, 138, 134, 0.9));
    box-shadow: 0 0 60px rgba(111, 168, 164, 0.28), inset 0 0 30px rgba(255, 255, 255, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: scale(1);
    transition: transform 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  .breath-circle.inhale { transform: scale(2.0); }
  .breath-circle.exhale { transform: scale(1.0); }
  .breath-cue {
    color: rgba(255, 255, 255, 0.95);
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    font-weight: 300;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.18);
    user-select: none;
    pointer-events: none;
  }

  /* === meta card === */
  .etude-card {
    background: var(--bg-soft);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
  }
  .breath-meta-card {
    margin: 0 0 1.5rem;
    font-variant-numeric: tabular-nums;
  }
  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0.3rem 0;
  }
  .meta-label {
    font-size: var(--label-size);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    font-weight: 600;
  }
  .meta-val {
    color: var(--text);
    font-weight: 500;
  }
  .progress {
    width: 100%;
    height: 3px;
    background: var(--line);
    border-radius: 2px;
    margin-top: 0.85rem;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    width: 0%;
    background: var(--accent);
    transition: width 240ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* === controls === */
  .controls {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    align-items: center;
    margin: 0 0 1.5rem;
  }

  /* primary filled pill */
  .etude-next {
    appearance: none;
    -webkit-appearance: none;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.65rem 1.4rem;
    min-height: 2.75rem;
    border: none;
    background: var(--text);
    color: var(--bg);
    border-radius: 999px;
    cursor: pointer;
    transition: background 240ms ease, transform 180ms ease, opacity 240ms ease;
  }
  .etude-next:hover:not(:disabled) {
    background: var(--accent);
  }
  .etude-next:active:not(:disabled) {
    transform: scale(0.97);
  }
  .etude-next:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .etude-next:disabled {
    opacity: 0.45;
    cursor: default;
  }

  /* secondary quiet button */
  .etude-quiet {
    appearance: none;
    -webkit-appearance: none;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.6rem 1.1rem;
    min-height: 2.75rem;
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    cursor: pointer;
    transition: color 240ms ease, border-color 240ms ease, background 240ms ease, transform 180ms ease;
  }
  .etude-quiet:hover:not(:disabled) {
    color: var(--text);
    border-color: var(--text);
  }
  .etude-quiet:active:not(:disabled) {
    transform: scale(0.97);
  }
  .etude-quiet:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .etude-quiet:disabled {
    opacity: 0.45;
    cursor: default;
  }
  .etude-quiet-ghost {
    border-style: dashed;
    font-size: 0.85rem;
  }

  /* === result === */
  .result { margin: 0 0 1rem; min-height: 1rem; }
  .result:not(:empty) {
    background: var(--bg-soft);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--accent);
  }
  .result-headline {
    font-family: var(--serif-display);
    font-size: 1.25rem;
    margin: 0 0 0.45rem;
    color: var(--text);
    letter-spacing: -0.005em;
  }
  .result-body {
    margin: 0;
    color: var(--text);
    line-height: 1.6;
  }

  /* === coda === */
  .etude-coda {
    margin: 2.5rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }
  .etude-coda p {
    color: var(--muted);
    font-style: italic;
    line-height: 1.6;
    margin: 0;
  }

  /* === mobile === */
  @media (max-width: 32rem) {
    .etude-title { font-size: 1.85rem; }
    .breath-stage { height: 18rem; margin: 2rem 0 1.5rem; border-radius: 10px; }
    .breath-circle { width: 6rem; height: 6rem; }
    .etude-card { padding: 1.1rem 1.15rem; border-radius: 10px; }
    .controls { gap: 0.5rem; }
    .etude-next { padding: 0.6rem 1.2rem; }
    .etude-quiet { padding: 0.55rem 1rem; }
    .result:not(:empty) { padding: 1.1rem 1.15rem; border-radius: 10px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .breath-circle { transition: transform 200ms linear !important; }
    .progress-fill { transition: width 100ms linear; }
  }
</style>
