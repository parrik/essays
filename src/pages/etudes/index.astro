---
import Base from '../../layouts/Base.astro';

const families = [
  {
    title: 'Campaign Cascade',
    parents: [
      { label: 'How to run a cross-cutting campaign', href: '/essays/the-campaign-cascade/' },
    ],
    etudes: [
      { name: 'Review this PR', href: '/etudes/campaign-cascade/review-this-pr/', desc: '30 seconds in the seat where the cascade lands.' },
      { name: 'Three Paths', href: '/etudes/campaign-cascade/three-paths/', desc: 'Pick the path for each of four scenarios.' },
      { name: 'Cascade Simulator', href: '/etudes/campaign-cascade/cascade-simulator/', desc: 'Watch the failure mode fire across a fleet.' },
    ],
  },
  {
    title: 'Know Thyself',
    parents: [
      { label: 'A self was never flat', href: '/essays/know-thyself/' },
      { label: 'Search was never about humans', href: '/essays/know-thyself-search/' },
    ],
    etudes: [
      { name: 'Token Budget', href: '/etudes/know-thyself/token-budget/', desc: 'Slide the graph size; watch the paste break.' },
      { name: 'Two Queries', href: '/etudes/know-thyself/two-queries/', desc: 'Type like a human, then like an agent.' },
      { name: 'Flat vs Typed', href: '/etudes/know-thyself/flat-vs-typed/', desc: 'Same data, two memories.' },
      { name: 'Six Restatements', href: '/etudes/know-thyself/six-restatements/', desc: 'One claim said six ways is one derivation, not six.' },
      { name: 'Attribution ≠ Confidence', href: '/etudes/know-thyself/attribution-confidence/', desc: 'Drill the rule across six scenarios.' },
    ],
  },
  {
    title: 'Restorative',
    parents: [
      { label: 'The Partition Problem', href: '/essays/the-partition-problem/' },
    ],
    etudes: [
      { name: 'Long Exhale', href: '/etudes/restorative/long-exhale/', desc: '4-in / 8-out for two minutes; the parasympathetic comes online.' },
      { name: 'Coming Home', href: '/etudes/restorative/coming-home/', desc: 'Two-hour routine. Anxious, hypervigilant, unsafe in your body.' },
      { name: 'Tending the Ember', href: '/etudes/restorative/tending-the-ember/', desc: 'Two-hour routine. Depleted, heavy, low.' },
      { name: 'The Open Sky', href: '/etudes/restorative/the-open-sky/', desc: 'Two-hour routine. Ready to unbind and expand.' },
    ],
  },
];
---
<Base title="etudes">
  <section class="intro">
    <h1>etudes</h1>
    <p>Short interactive studies. One claim, one interaction, two to ten minutes. The interaction does cognitive work the prose can't &mdash; your own response is the lesson.</p>
  </section>

  {families.map(family => (
    <section class="etude-family">
      <h2 class="etude-family-name">{family.title}</h2>
      <p class="etude-family-parents">
        Companion to {family.parents.map((p, i) => (
          <>
            <a href={p.href}>{p.label}</a>{i < family.parents.length - 2 ? ', ' : i === family.parents.length - 2 ? ' and ' : '.'}
          </>
        ))}
      </p>
      <ul class="etude-list">
        {family.etudes.map(e => (
          <li>
            <a href={e.href} class="etude-link">
              <span class="etude-name">{e.name}</span>
              <span class="etude-sep"> &mdash; </span>
              <span class="etude-desc">{e.desc}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>

<style>
  .etude-family {
    margin: 2rem 0;
  }
  .etude-family-name {
    font-family: var(--sans);
    font-size: var(--label-size);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin: 0 0 0.35rem 0;
  }
  .etude-family-parents {
    margin: 0 0 0.85rem 0;
    font-size: 0.92rem;
    color: var(--muted);
    font-style: italic;
  }
  .etude-family-parents a {
    color: var(--muted);
  }
  .etude-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .etude-list li {
    margin: 0;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--line);
  }
  .etude-list li:last-child {
    border-bottom: none;
  }
  .etude-link {
    display: block;
    text-decoration: none;
    color: var(--text);
    line-height: 1.45;
  }
  .etude-name {
    font-weight: 600;
  }
  .etude-link:hover .etude-name {
    color: var(--accent);
    text-decoration: underline;
  }
  .etude-sep {
    color: var(--muted);
  }
  .etude-desc {
    color: var(--muted);
  }
  @media (max-width: 32rem) {
    .etude-sep { display: none; }
    .etude-desc {
      display: block;
      font-size: 0.92rem;
      margin-top: 0.15rem;
    }
  }
</style>
