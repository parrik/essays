---
import Base from '../../../layouts/Base.astro';
const title = 'Find one note. There are 1,247 of them.';
const subtitle = 'Storage went up. Memory went down. A playable rediscovery loop.';
---
<Base title={title} description={subtitle}>
  <article class="etude">
    <p class="essay-kicker">Etude · Memory was never about storage</p>
    <h1>{title}</h1>
    <p class="essay-sub">{subtitle}</p>
    <div class="essay-meta">
      <a href="/essays/memory-was-never-about-storage/">← back to essay</a>
    </div>
    <hr />

    <p class="goal">Your goal: find the one note that says <em>"the index is the memory, not the substrate."</em> It's in there. Somewhere.</p>

    <div class="search-bar">
      <input id="q" type="text" placeholder="Search your notes." autocomplete="off" />
      <span id="status" class="status">1,247 notes loaded.</span>
    </div>

    <div id="wall" class="wall" aria-label="Note wall"></div>

    <div id="banner" class="banner" hidden></div>

    <hr />

    <p>Storage went up. Memory went down. The notes were never the memory; the access shape was. A typed graph with provenance and edges turns this same substrate from a graveyard into an index — but only if you build the access affordance, not just write more notes.</p>
    <p class="footnote">Background: Andy Matuschak's <a href="https://notes.andymatuschak.org/Evergreen_notes" target="_blank" rel="noopener">evergreen-notes retrospective</a> after 1000+ notes — dense interconnection impaired recall. Rediscovery loops eat the gains.</p>
  </article>
</Base>

<script is:inline>
  // Deterministic LCG so the wall is identical every render.
  function lcg(seed) {
    let s = seed >>> 0;
    return function () {
      s = (Math.imul(s, 1664525) + 1013904223) >>> 0;
      return s / 4294967296;
    };
  }
  const rand = lcg(20260429);
  const TOTAL = 1247;
  const TARGET_INDEX = 847;
  const TARGET_TEXT = 'the index is the memory, not the substrate';

  const KEYWORDS = ['entropy', 'compression', 'feedback', 'system', 'boundary', 'context', 'signal', 'gradient', 'state', 'frame', 'loop', 'channel'];
  const VERBS = ['decays into', 'compresses against', 'retrieves through', 'collapses onto', 'leaks into', 'indexes against', 'shadows', 'mirrors', 'inverts', 'thresholds against'];
  const QUALIFIERS = ['under load', 'at the boundary', 'in steady state', 'as substrate', 'across the channel', 'absent context', 'at the index', 'under recall pressure', 'when over-archived', 'at scale'];
  const HEDGES = ['cf.', 'compare', 'adjacent to', 'see also', 'relates to', 'tension with', 'dual of'];

  function id6(r) {
    const chars = 'abcdefghijklmnopqrstuvwxyz0123456789';
    let s = '';
    for (let i = 0; i < 6; i++) s += chars[Math.floor(r() * chars.length)];
    return s;
  }

  function fragment(r) {
    const a = KEYWORDS[Math.floor(r() * KEYWORDS.length)];
    const v = VERBS[Math.floor(r() * VERBS.length)];
    const b = KEYWORDS[Math.floor(r() * KEYWORDS.length)];
    const q = QUALIFIERS[Math.floor(r() * QUALIFIERS.length)];
    const h = HEDGES[Math.floor(r() * HEDGES.length)];
    const c = KEYWORDS[Math.floor(r() * KEYWORDS.length)];
    return `${a} ${v} ${b} ${q}; ${h} ${c}`;
  }

  const notes = [];
  for (let i = 0; i < TOTAL; i++) {
    if (i === TARGET_INDEX) {
      notes.push({ id: id6(rand), text: TARGET_TEXT });
    } else {
      notes.push({ id: id6(rand), text: fragment(rand) });
    }
  }

  const wall = document.getElementById('wall');
  const frag = document.createDocumentFragment();
  for (const n of notes) {
    const d = document.createElement('div');
    d.className = 'note';
    d.dataset.text = n.text.toLowerCase();
    d.innerHTML = `<span class="nid">${n.id}</span> ${n.text}`;
    frag.appendChild(d);
  }
  wall.appendChild(frag);

  const q = document.getElementById('q');
  const status = document.getElementById('status');
  const banner = document.getElementById('banner');
  let searchCount = 0;
  let hits = [];
  let cursor = -1;
  let bannerShown = false;

  function clearHighlights() {
    for (const el of wall.querySelectorAll('.note.hit, .note.active')) {
      el.classList.remove('hit', 'active');
    }
  }

  function search() {
    const term = q.value.trim().toLowerCase();
    clearHighlights();
    hits = [];
    cursor = -1;
    if (!term) {
      status.textContent = '1,247 notes loaded.';
      return;
    }
    searchCount++;
    const all = wall.querySelectorAll('.note');
    for (const el of all) {
      if (el.dataset.text.includes(term)) {
        el.classList.add('hit');
        hits.push(el);
      }
    }
    status.textContent = `${hits.length} hit${hits.length === 1 ? '' : 's'} for "${term}". Tab to step through.`;
    if (hits.length > 0) {
      cursor = 0;
      hits[0].classList.add('active');
      hits[0].scrollIntoView({ block: 'center', behavior: 'smooth' });
    }
    if (searchCount >= 10) showBanner();
  }

  function step(dir) {
    if (hits.length === 0) return;
    if (cursor >= 0) hits[cursor].classList.remove('active');
    cursor = (cursor + dir + hits.length) % hits.length;
    hits[cursor].classList.add('active');
    hits[cursor].scrollIntoView({ block: 'center', behavior: 'smooth' });
    status.textContent = `${cursor + 1} of ${hits.length} hits.`;
  }

  function showBanner() {
    if (bannerShown) return;
    bannerShown = true;
    banner.hidden = false;
    banner.innerHTML = `<strong>You stored 1,247 notes.</strong> The one you needed has been here all along (note #${TARGET_INDEX + 1}). This is what Matuschak called the <em>rediscovery loop</em> — interconnection grew, recall didn't.`;
  }

  q.addEventListener('input', search);
  q.addEventListener('keydown', (e) => {
    if (e.key === 'Tab') {
      e.preventDefault();
      step(e.shiftKey ? -1 : 1);
    }
  });

  setTimeout(showBanner, 30000);
</script>

<style>
  .etude { max-width: 48rem; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
  .etude h1 { font-family: 'Georgia', serif; font-size: 2rem; margin: 0.5rem 0 0.5rem; }
  .essay-sub { font-style: italic; color: var(--muted); margin: 0 0 1rem; }
  .goal {
    padding: 0.75rem 1rem;
    background: rgba(138, 52, 32, 0.06);
    border-left: 3px solid var(--accent);
    border-radius: 2px;
    margin: 1rem 0;
  }
  .search-bar {
    position: sticky;
    top: 0;
    z-index: 5;
    background: var(--bg);
    padding: 0.6rem 0;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  #q {
    flex: 1;
    min-width: 14rem;
    font-family: inherit;
    font-size: 1rem;
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--accent);
    border-radius: 3px;
    background: var(--bg);
    color: var(--ink);
  }
  .status { font-size: 0.85rem; color: var(--muted); font-style: italic; }
  .wall {
    margin: 1rem 0;
    height: 28rem;
    overflow-y: scroll;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 3px;
    padding: 0.4rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
    gap: 2px;
    background: rgba(0,0,0,0.015);
  }
  .note {
    font-size: 0.62rem;
    line-height: 1.25;
    color: rgba(0,0,0,0.42);
    padding: 0.25rem 0.35rem;
    background: rgba(255,255,255,0.5);
    border-radius: 2px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-family: 'Menlo', monospace;
  }
  .note .nid {
    color: rgba(0,0,0,0.28);
    font-weight: 600;
    margin-right: 0.25rem;
  }
  .note.hit {
    background: rgba(255, 220, 100, 0.5);
    color: rgba(0,0,0,0.75);
  }
  .note.active {
    background: rgba(138, 52, 32, 0.85);
    color: #fff;
    outline: 2px solid var(--accent);
  }
  .note.active .nid { color: rgba(255,255,255,0.7); }
  .banner {
    margin: 1rem 0;
    padding: 1rem 1.15rem;
    border-left: 3px solid var(--accent);
    background: rgba(138, 52, 32, 0.08);
    border-radius: 2px;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .footnote { font-size: 0.85rem; color: var(--muted); margin-top: 1rem; }
  @media (prefers-color-scheme: dark) {
    .wall { background: rgba(255,255,255,0.02); }
    .note { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.4); }
    .note .nid { color: rgba(255,255,255,0.3); }
    .note.hit { color: rgba(255,255,255,0.9); }
  }
</style>
