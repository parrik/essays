---
import Base from '../../../layouts/Base.astro';
import GraphNode from '../../../components/GraphNode.astro';
import IssueLink from '../../../components/IssueLink.astro';

const slug = 'the-partition-problem';
const essayTitle = 'The Partition Problem';
const subtitle = 'The essay\'s knowledge, dashboard-shaped — graph, eyes, actions.';

type NodeType = 'synthesis' | 'citation' | 'derivation' | 'observation';
type Node = {
  id: string;
  type: NodeType;
  claim: string;
  where?: string;
  source?: string;
  url?: string;
  derives_from?: string[];
  why?: string;
};

const nodes: Node[] = [
  {
    id: 'S01-cancer-cell-lost-context',
    type: 'synthesis',
    claim: 'A cancer cell is not a broken cell — it has lost context.',
    where: 'opening',
    why: 'The spine. Reframes cancer from machinery-failure to signal-failure: the cell still functions, but inside a model of the world that is no longer true.',
  },
  {
    id: 'C01-hanahan-weinberg',
    type: 'citation',
    claim: 'Hallmarks of Cancer (2011) + New Dimensions (2022) — cancer as acquired capabilities that escape tissue signaling and microenvironmental constraint.',
    where: 'footnote [^1]',
    source: 'Hanahan & Weinberg, Cell 2011; Cancer Discovery 2022',
    url: 'https://www.cell.com/cell/fulltext/S0092-8674(11)00127-9',
    why: 'Grounds the spine in the canonical cancer-biology frame. The 2011 update foregrounds tumor-promoting inflammation and microenvironment — the bridge the essay builds on.',
  },
  {
    id: 'C02-sonnenschein-soto',
    type: 'citation',
    claim: 'Tissue Organization Field Theory — cancer as tissue-level disorder of intercellular constraint.',
    where: 'footnote [^1]',
    source: 'Sonnenschein & Soto',
    why: 'The minority-position citation that takes the context-loss frame furthest. Pairs with Hanahan-Weinberg to triangulate the spine claim from two independent literatures.',
  },
  {
    id: 'C03-mccarthy-okg',
    type: 'citation',
    claim: 'Open-knowledge-graph — bounded-context framework. Paper 11 (The Ratchet) and Paper 5 (Genome as Projection).',
    where: 'footnote [^1]',
    source: 'Patrick D. McCarthy',
    url: 'https://github.com/patdmc/open-knowledge-graph',
    why: 'The theoretical scaffolding the essay leans on — cancer and evolution as opposing failures of the same bounded-context mechanism.',
  },
  {
    id: 'D01-fascia-partitions',
    type: 'derivation',
    claim: 'Fascia partitions — the body partitions itself when signal is associated with danger.',
    where: 'fascia section',
    derives_from: ['S01-cancer-cell-lost-context', 'C04-schleip-stecco'],
    why: 'The somatic instantiation of the spine. What context-loss looks like in connective tissue: dehydration, adhesion, regions stop participating, force routes around them.',
  },
  {
    id: 'C04-schleip-stecco',
    type: 'citation',
    claim: 'Fascia hydration and hyaluronan-driven interlayer glide; densification compromises the system.',
    where: 'footnote [^schleip]',
    source: 'Schleip et al. (2012, 2015); Stecco et al. (2011)',
    url: 'https://pubmed.ncbi.nlm.nih.gov/21964857/',
    why: 'Grounds the fascia mechanism. The hyaluronan / glide / densification chain is solid in the bodywork literature; the essay borrows it cleanly.',
  },
  {
    id: 'D02-restorative-reopens-channel',
    type: 'derivation',
    claim: 'Restorative yoga reopens the channel — long supported holds let the matrix re-hydrate, adhesions soften, the partitioned region rejoins surrounding signal.',
    where: 'fascia section',
    derives_from: ['D01-fascia-partitions'],
    why: 'The intervention claim at the fascia layer. Mechanism-level (re-hydration, adhesion-softening), not outcome-level (cure).',
  },
  {
    id: 'D03-vagus-listening-line',
    type: 'derivation',
    claim: 'The vagus is the body\'s listening line — long exhale signals safety; HRV measures its flexibility.',
    where: 'long exhale section',
    derives_from: ['S01-cancer-cell-lost-context', 'C05-porges'],
    why: 'The nervous-system instantiation of the spine. Locked vagus reads alarm; flexible vagus reads context. Same partition dynamic, different tissue.',
  },
  {
    id: 'C05-porges',
    type: 'citation',
    claim: 'Polyvagal theory — vagal tone, supported postures, long exhales, inflammation-vagal-tone correlation. Phylogenetic claims contested by Grossman/Taylor; clinical readouts robust.',
    where: 'footnote [^porges]',
    source: 'Porges 2011; Grossman & Taylor 2007',
    why: 'Honest citation. Theory is contested at the phylogenetic layer; the load-bearing readouts (HRV, exhale, vagal-tone-inflammation) replicate independently.',
  },
  {
    id: 'C06-williams-hrv',
    type: 'citation',
    claim: 'HRV–inflammation meta-analysis — vagally-mediated HRV inversely tracks circulating inflammatory markers via the cholinergic anti-inflammatory pathway.',
    where: 'footnote [^hrv]',
    source: 'Williams et al., Brain, Behavior, and Immunity (2019)',
    url: 'https://pubmed.ncbi.nlm.nih.gov/30872091/',
    why: 'The bridge citation. Provides the HRV-to-inflammation half of the synthesis; the inflammation-to-cancer-permissive half comes from Hanahan-Weinberg. Neither paper makes the full bridge.',
  },
  {
    id: 'S02-cell-that-lost-the-signal',
    type: 'synthesis',
    claim: 'A cancer cell is a cell that has lost the signal that says: you are held.',
    where: 'closer',
    derives_from: ['S01-cancer-cell-lost-context', 'D01-fascia-partitions', 'D03-vagus-listening-line', 'C06-williams-hrv'],
    why: 'The full synthesis. Connects hallmarks-of-cancer to the nervous-system / fascia frame — same partition dynamic, three tissues. Not a cure claim; a frame claim.',
  },
];

type EyesItem = {
  id: string;
  what: string;
  why: string;
  ground_with?: { label: string; url?: string }[];
};

const eyes: EyesItem[] = [
  {
    id: 'C06-williams-hrv',
    what: 'The HRV → inflammation → cancer-permissive bridge is the author\'s synthesis across three literatures, not a cited consensus. The footnote names this explicitly; flagging here for transparency.',
    why: 'Williams 2019 covers HRV-to-inflammation; Hanahan-Weinberg names tumor-promoting inflammation as enabling characteristic. No single paper closes the loop. Worth empirical follow-up.',
    ground_with: [
      { label: 'Williams et al. 2019 — HRV-inflammation meta-analysis', url: 'https://pubmed.ncbi.nlm.nih.gov/30872091/' },
      { label: 'Hanahan & Weinberg 2011 — tumor-promoting inflammation as enabling characteristic', url: 'https://www.cell.com/cell/fulltext/S0092-8674(11)00127-9' },
    ],
  },
  {
    id: 'D02-restorative-reopens-channel',
    what: '"Restorative yoga cannot cure cancer" is the disclaimer. The positive claim — reopening the partition channel — is mechanism-level, not outcome-level.',
    why: 'Mechanism plausibility (matrix re-hydration, adhesion softening) draws on mechanical-loading studies, not restorative-yoga trials. Some oncology supportive-care trials of yoga exist; worth citing if findable.',
    ground_with: [
      { label: 'Yoga in oncology supportive care — supportive-care trials', url: 'https://www.ncbi.nlm.nih.gov/pmc/articles/PMC5871291/' },
    ],
  },
  {
    id: 'S02-cell-that-lost-the-signal',
    what: 'The bridge from "cell-autonomous capabilities" (Hanahan-Weinberg) to "cell that lost the signal you are held" is poetic synthesis, not a direct mapping in the source.',
    why: 'The frame is load-bearing for the essay. The 2011 + 2022 hallmarks updates do foreground microenvironment and inflammation, which makes the bridge defensible — but the affective register ("held") is the author\'s addition, not the literature\'s.',
  },
  {
    id: 'D01-fascia-partitions',
    what: 'The fascia mechanism (hydration, glide, densification) is solid for mechanical-loading contexts. The bridge from "long supported holds" to "matrix re-hydrates" is mechanism-plausible but not directly observed in restorative-yoga studies.',
    why: 'Schleip + Stecco grounds the tissue mechanics; the specific intervention pathway (long supported holds → ANS-mediated viscosity change → re-hydration) is inferred from Schleip Part 2 (ANS-mediated viscosity changes), not directly trialed.',
    ground_with: [
      { label: 'Schleip "Fascial plasticity Part 2" — ANS-mediated viscosity', url: 'https://www.fasciaresearch.de/' },
    ],
  },
];

type ActionItem = {
  label: string;
  body: string;
  href?: string;
  kind: 'etude' | 'apply' | 'next';
};

const actions: ActionItem[] = [
  {
    kind: 'etude',
    label: 'Long Exhale',
    body: '4-in / 8-out for two minutes. Drills D03 — the vagus reading safety from breath shape.',
    href: '/etudes/restorative/long-exhale/',
  },
  {
    kind: 'etude',
    label: 'Tending the Ember',
    body: 'Full restorative routine. Long supported holds at the fascial layer. Drills D01 + D02.',
    href: '/etudes/restorative/tending-the-ember/',
  },
  {
    kind: 'etude',
    label: 'Coming Home',
    body: 'Full restorative routine. Re-establishes the broadcast across nervous system and fascia.',
    href: '/etudes/restorative/coming-home/',
  },
  {
    kind: 'etude',
    label: 'The Open Sky',
    body: 'Full restorative routine. Sustained witnessed stillness — the closer\'s "you are held" at body scale.',
    href: '/etudes/restorative/the-open-sky/',
  },
  {
    kind: 'apply',
    label: 'Find a partitioned region',
    body: 'Locate one fascial region in your body that has stopped participating — chronic shoulder, hip, ribcage. Spend 90 seconds in supported child\'s pose with breath at 4:8 ratio. Notice the local re-hydration cue.',
  },
  {
    kind: 'apply',
    label: 'Map sympathetic dominance',
    body: 'Walk through your day: where does sympathetic dominance climb? Where could you stack a 2-minute long-exhale break? The vagus listens to whatever cadence you teach it.',
  },
  {
    kind: 'next',
    label: 'Same partition pattern, different scale',
    body: 'Know-thyself Part I argues the same shape at memory scale — flat memory partitions claims from their evidence the way braced fascia partitions tissue from signal.',
    href: '/puzzles/know-thyself/',
  },
];

const typeMeta: Record<NodeType, { letter: string; label: string; chip: string }> = {
  synthesis: { letter: 'S', label: 'synthesis', chip: 'chip-emg' },
  citation: { letter: 'C', label: 'citation', chip: 'chip-eqv' },
  derivation: { letter: 'D', label: 'derivation', chip: 'chip-ovl' },
  observation: { letter: 'O', label: 'observation', chip: 'chip-obs' },
};

const counts = nodes.reduce(
  (acc, n) => {
    acc[n.type] = (acc[n.type] || 0) + 1;
    return acc;
  },
  {} as Record<NodeType, number>,
);

type NodePos = { cx: number; cy: number; r: number; labelY: number; labelText: string };
const positions: Record<string, NodePos> = {
  // spine — center top
  'S01-cancer-cell-lost-context':   { cx: 340, cy: 100, r: 34, labelY: 152, labelText: 'S01 · spine' },
  // citations clustered near spine
  'C01-hanahan-weinberg':           { cx: 220, cy: 50,  r: 20, labelY: 22,  labelText: 'C01' },
  'C02-sonnenschein-soto':          { cx: 460, cy: 50,  r: 20, labelY: 22,  labelText: 'C02' },
  'C03-mccarthy-okg':               { cx: 600, cy: 100, r: 20, labelY: 142, labelText: 'C03' },
  // fascia branch (left subtree)
  'D01-fascia-partitions':          { cx: 180, cy: 230, r: 26, labelY: 275, labelText: 'D01' },
  'C04-schleip-stecco':             { cx: 60,  cy: 230, r: 20, labelY: 272, labelText: 'C04' },
  'D02-restorative-reopens-channel':{ cx: 180, cy: 360, r: 24, labelY: 403, labelText: 'D02' },
  // vagus branch (right subtree)
  'D03-vagus-listening-line':       { cx: 500, cy: 230, r: 26, labelY: 275, labelText: 'D03' },
  'C05-porges':                     { cx: 620, cy: 230, r: 20, labelY: 272, labelText: 'C05' },
  'C06-williams-hrv':               { cx: 620, cy: 320, r: 20, labelY: 362, labelText: 'C06' },
  // synthesis closer — bottom center
  'S02-cell-that-lost-the-signal':  { cx: 340, cy: 420, r: 30, labelY: 470, labelText: 'S02 · closer' },
};
---
<Base title={`Knowledge dashboard — ${essayTitle}`} description={subtitle}>
  <article class="dash-page">
    <header class="dash-head">
      <p class="dash-kicker">Knowledge dashboard</p>
      <h1 class="dash-title">{essayTitle}</h1>
      <p class="dash-relief">{subtitle}</p>
      <nav class="dash-back">
        <a href={`/puzzles/${slug}/`}>← essay</a>
      </nav>
    </header>

    <nav class="tabbar" role="tablist">
      <button type="button" data-tab="graph" class="active" role="tab" aria-selected="true">Graph</button>
      <button type="button" data-tab="eyes" role="tab" aria-selected="false">Eyes <span class="tab-count">{eyes.length}</span></button>
      <button type="button" data-tab="actions" role="tab" aria-selected="false">Actions <span class="tab-count">{actions.length}</span></button>
    </nav>

    <section id="tab-graph" class="tab-panel active" role="tabpanel">
      <p class="tab-lead">The essay's claims, typed and connected. <strong>S</strong>ynthesis is the author's contribution. <strong>C</strong>itation grounds in a named source. <strong>D</strong>erivation follows from prior nodes. Click any node to jump to its card.</p>

      <div class="graph-viz">
        <svg viewBox="0 0 680 480" role="img" aria-label="Knowledge graph — the partition problem">
          {/* edges first so nodes paint over them */}
          {/* spine grounded by citations */}
          <line x1="220" y1="50"  x2="340" y2="100" class="edge edge-derives" />
          <line x1="460" y1="50"  x2="340" y2="100" class="edge edge-derives" />
          <line x1="600" y1="100" x2="340" y2="100" class="edge edge-derives" />
          {/* fascia branch derives from spine + Schleip */}
          <line x1="180" y1="230" x2="340" y2="100" class="edge edge-derives" />
          <line x1="180" y1="230" x2="60"  y2="230" class="edge edge-derives" />
          {/* restorative reopens derives from fascia partitions */}
          <line x1="180" y1="360" x2="180" y2="230" class="edge edge-derives" />
          {/* vagus branch derives from spine + Porges */}
          <line x1="500" y1="230" x2="340" y2="100" class="edge edge-derives" />
          <line x1="500" y1="230" x2="620" y2="230" class="edge edge-derives" />
          {/* closer derives from spine + fascia branch + vagus branch + Williams */}
          <line x1="340" y1="420" x2="340" y2="100" class="edge edge-derives" />
          <line x1="340" y1="420" x2="180" y2="230" class="edge edge-derives" />
          <line x1="340" y1="420" x2="500" y2="230" class="edge edge-derives" />
          <line x1="340" y1="420" x2="620" y2="320" class="edge edge-derives" />

          {nodes.map((n) => {
            const p = positions[n.id];
            if (!p) return null;
            return (
              <GraphNode
                type={n.type}
                cx={p.cx}
                cy={p.cy}
                r={p.r}
                isSpine={n.id === 'S01-cancer-cell-lost-context'}
                id={n.id}
                claim={n.claim}
                why={n.why}
                where={n.where}
                label={p.labelText}
                letter={typeMeta[n.type].letter}
                typeLabel={typeMeta[n.type].label}
                labelY={p.labelY}
              />
            );
          })}
        </svg>
        <div id="viz-tooltip" class="viz-tooltip" aria-hidden="true"></div>
      </div>

      <div class="dash-counts">
        {(Object.keys(counts) as NodeType[]).map((t) => (
          <span class={`chip ${typeMeta[t].chip}`}>
            {typeMeta[t].letter}
            <span class="chip-count"> {counts[t]}</span>
          </span>
        ))}
      </div>

      <div class="graph-nodes">
        {nodes.map((n) => (
          <article class={`graph-node graph-node-${n.type}`} id={n.id}>
            <p class="graph-node-head">
              <span class={`chip ${typeMeta[n.type].chip}`}>{typeMeta[n.type].letter}</span>
              <code class="graph-node-id">{n.id}</code>
              {n.where && <span class="graph-node-where">· {n.where}</span>}
            </p>
            <p class="graph-node-claim">{n.claim}</p>
            {n.source && (
              <p class="graph-node-source">
                <span class="graph-node-edge-label">grounds:</span>{' '}
                {n.url ? <a href={n.url} rel="noopener">{n.source}</a> : <span>{n.source}</span>}
              </p>
            )}
            {n.derives_from && n.derives_from.length > 0 && (
              <p class="graph-node-derives">
                <span class="graph-node-edge-label">derives_from:</span>{' '}
                {n.derives_from.map((d, i) => (
                  <>
                    {i > 0 && ', '}
                    <a href={`#${d}`}><code>{d}</code></a>
                  </>
                ))}
              </p>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="tab-eyes" class="tab-panel" role="tabpanel">
      <p class="tab-lead">Claims that need more grounding. The essay's confident synthesis — but where external corroboration would strengthen the case, or an open question is implicit.</p>

      <div class="eyes-list">
        {eyes.map((e) => (
          <article class="eyes-item">
            <p class="eyes-item-head">
              <a href={`#${e.id}`} class="eyes-item-id"><code>{e.id}</code></a>
            </p>
            <p class="eyes-what">{e.what}</p>
            <p class="eyes-why"><em>Why eyes:</em> {e.why}</p>
            {e.ground_with && e.ground_with.length > 0 && (
              <p class="eyes-ground">
                <span class="eyes-ground-label">ground_with:</span>
                <ul>
                  {e.ground_with.map((g) => (
                    <li>
                      {g.url ? <a href={g.url} rel="noopener">{g.label}</a> : <span>{g.label}</span>}
                    </li>
                  ))}
                </ul>
              </p>
            )}
            <p class="card-cta">
              <IssueLink kind="eyes" slug={slug} item={e} />
            </p>
          </article>
        ))}
      </div>
    </section>

    <section id="tab-actions" class="tab-panel" role="tabpanel">
      <p class="tab-lead">What the essay implies for the reader. Etudes drill specific claims; <em>apply</em> items put the principle to work; <em>next</em> points at sibling essays.</p>

      <div class="actions-list">
        {actions.map((a) => (
          <article class={`actions-item actions-item-${a.kind}`}>
            <p class="actions-item-head">
              <span class={`actions-kind actions-kind-${a.kind}`}>{a.kind}</span>
              {a.href ? (
                <a href={a.href} class="actions-item-label">{a.label} →</a>
              ) : (
                <span class="actions-item-label">{a.label}</span>
              )}
            </p>
            <p class="actions-item-body">{a.body}</p>
            {a.kind === 'apply' && (
              <p class="card-cta">
                <IssueLink kind="apply" slug={slug} item={a} />
              </p>
            )}
          </article>
        ))}
      </div>
    </section>
  </article>
</Base>

<script is:inline>
  document.querySelectorAll('.tabbar [data-tab]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const name = btn.getAttribute('data-tab');
      document.querySelectorAll('.tabbar [data-tab]').forEach((b) => {
        const active = b.getAttribute('data-tab') === name;
        b.classList.toggle('active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      document.querySelectorAll('.tab-panel').forEach((p) => {
        p.classList.toggle('active', p.id === 'tab-' + name);
      });
    });
  });

  // Deep-link via hash: #tab-eyes / #tab-actions / #tab-graph
  const hash = window.location.hash.replace('#', '');
  if (hash.startsWith('tab-')) {
    const name = hash.slice(4);
    const btn = document.querySelector(`.tabbar [data-tab="${name}"]`);
    if (btn) btn.click();
  }
  // Node click in viz → switch back to graph tab if needed, then anchor handles it
  document.querySelectorAll('.viz-node-link').forEach((a) => {
    a.addEventListener('click', () => {
      const graphBtn = document.querySelector('.tabbar [data-tab="graph"]');
      if (graphBtn && !graphBtn.classList.contains('active')) graphBtn.click();
    });
  });

  // Hover tooltip on graph nodes — pattern from /example-graph-full.html
  const tip = document.getElementById('viz-tooltip');
  if (tip) {
    const escape = (s) => String(s || '').replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[c]));

    document.querySelectorAll('.viz-node-link').forEach((a) => {
      a.addEventListener('mouseenter', () => {
        const id = a.getAttribute('data-id');
        const claim = a.getAttribute('data-claim');
        const why = a.getAttribute('data-why');
        const type = a.getAttribute('data-type');
        const where = a.getAttribute('data-where');
        let html = '<div class="vt-type">' + escape(type);
        if (where) html += '<span class="vt-dot">·</span>' + escape(where);
        html += '</div>';
        html += '<div class="vt-id"><code>' + escape(id) + '</code></div>';
        html += '<div class="vt-claim">' + escape(claim) + '</div>';
        if (why) html += '<div class="vt-why"><span class="vt-label">Why this node:</span> ' + escape(why) + '</div>';
        tip.innerHTML = html;
        tip.classList.add('visible');
      });
      a.addEventListener('mouseleave', () => tip.classList.remove('visible'));
      a.addEventListener('mousemove', (e) => {
        const pad = 12;
        const margin = 6;
        const w = tip.offsetWidth || 280;
        const h = tip.offsetHeight || 100;
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        let x = e.clientX + pad;
        if (x + w > vw - margin) x = e.clientX - w - pad;
        if (x < margin) x = margin;
        if (x + w > vw - margin) x = vw - w - margin;
        let y = e.clientY + pad;
        if (y + h > vh - margin) y = e.clientY - h - pad;
        if (y < margin) y = margin;
        tip.style.left = x + 'px';
        tip.style.top = y + 'px';
      });
    });
  }
</script>

<style is:global>
  .dash-page {
    max-width: 44rem;
    margin: 0 auto;
  }
  .dash-head {
    margin-bottom: 1.5rem;
  }
  .dash-kicker {
    font-family: var(--sans);
    font-size: var(--label-size);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin: 0 0 0.6rem;
  }
  .dash-title {
    font-family: var(--serif-display);
    font-size: 1.75rem;
    line-height: 1.2;
    margin: 0 0 0.35rem;
    letter-spacing: -0.005em;
  }
  .dash-relief {
    font-family: var(--serif);
    font-style: italic;
    color: var(--muted);
    font-size: 0.98rem;
    margin: 0 0 0.85rem;
    line-height: 1.5;
  }
  .dash-back {
    font-family: var(--sans);
    font-size: 0.85rem;
  }
  .dash-back a { color: var(--muted); text-decoration: none; }
  .dash-back a:hover { color: var(--accent); }

  /* === tabbar === */
  .tabbar {
    display: flex;
    gap: 0.4rem;
    margin: 1.5rem 0 1.5rem;
    padding: 0.3rem;
    background: var(--bg-soft);
    border-radius: 999px;
    width: fit-content;
  }
  .tabbar button {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--muted);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 240ms ease, color 240ms ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .tabbar button:hover {
