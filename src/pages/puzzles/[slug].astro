---
import Base from '../../layouts/Base.astro';
import MetadataStripe from '../../components/MetadataStripe.astro';
import PuzzleViews from '../../components/PuzzleViews.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(essay => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);

// Essays with a graph dashboard built. As more land, add the slug here.
const slugsWithGraph = new Set([
  'the-campaign-cascade',
  'know-thyself',
  'know-thyself-search',
  'know-thyself-security',
  'the-partition-problem',
]);
const hasGraph = slugsWithGraph.has(essay.id);

// Per-essay etude track. null = no etudes built yet.
const etudesBySlug: Record<string, string | null> = {
  'the-campaign-cascade': '/etudes/campaign-cascade/',
  'the-partition-problem': '/etudes/restorative/',
  'know-thyself': '/etudes/know-thyself/',
  'know-thyself-search': '/etudes/know-thyself/',
  'know-thyself-security': null,
};
const etudesUrl = etudesBySlug[essay.id] ?? null;
---
<Base title={essay.data.title} description={essay.data.description ?? essay.data.subtitle}>
  <article class="essay h-entry">
    {essay.data.kicker && <p class="essay-kicker">{essay.data.kicker}</p>}
    <h1 class="p-name">{essay.data.title}</h1>
    {(essay.data.subtitle || essay.data.relief) && (
      <p class="essay-sub p-summary">
        {essay.data.subtitle}
        {essay.data.subtitle && essay.data.relief && <span class="essay-sub-sep"> · </span>}
        {essay.data.relief && <em class="essay-sub-relief">{essay.data.relief}</em>}
      </p>
    )}
    <PuzzleViews
      slug={essay.id}
      activeView="essay"
      etudesUrl={etudesUrl}
      hasGraph={hasGraph}
    />
    <div class="essay-body e-content">
      <Content />
    </div>

    <footer class="essay-provenance">
      <MetadataStripe
        publishedAt={essay.data.publishedAt}
        updatedAt={essay.data.updatedAt}
        status={essay.data.status}
        confidence={essay.data.confidence}
      />
    </footer>

    <a class="u-url" href={`/puzzles/${essay.id}/`} hidden>{essay.data.title}</a>
    <span class="p-author h-card" hidden>parrik</span>
  </article>
</Base>
