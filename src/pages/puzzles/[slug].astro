---
import Base from '../../layouts/Base.astro';
import MetadataStripe from '../../components/MetadataStripe.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(essay => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);

// Essays with a graph page built. As more graphs land, add the slug here.
const slugsWithGraph = new Set(['the-campaign-cascade']);
const hasGraph = slugsWithGraph.has(essay.id);
---
<Base title={essay.data.title} description={essay.data.description ?? essay.data.subtitle}>
  <article class="essay h-entry">
    {essay.data.kicker && <p class="essay-kicker">{essay.data.kicker}</p>}
    <h1 class="p-name">{essay.data.title}</h1>
    {(essay.data.subtitle || essay.data.relief) && (
      <p class="essay-sub p-summary">
        {essay.data.subtitle}
        {essay.data.subtitle && essay.data.relief && <span class="essay-sub-sep"> · </span>}
        {essay.data.relief && <em class="essay-sub-relief">{essay.data.relief}</em>}
      </p>
    )}
    {/* Top-of-essay etudes picker removed by author preference: inline
        embeds in each section carry the engagement; no need for a top list.
        Schema + per-essay frontmatter retained for future use (e.g. an
        etudes index page). */}
    <MetadataStripe
      publishedAt={essay.data.publishedAt}
      updatedAt={essay.data.updatedAt}
      status={essay.data.status}
      confidence={essay.data.confidence}
    />
    <div class="essay-meta">
      <a href="/">← home</a>
      {hasGraph && <a href={`/puzzles/${essay.id}/graph/`}>knowledge dashboard</a>}
    </div>
    <hr />
    <div class="essay-body e-content">
      <Content />
    </div>
    <a class="u-url" href={`/puzzles/${essay.id}/`} hidden>{essay.data.title}</a>
    <span class="p-author h-card" hidden>parrik</span>
  </article>
</Base>
