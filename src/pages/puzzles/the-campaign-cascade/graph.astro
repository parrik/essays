---
import Base from '../../../layouts/Base.astro';

const slug = 'the-campaign-cascade';
const essayTitle = 'How to run a cross-cutting campaign';
const subtitle = 'The essay\'s knowledge, dashboard-shaped — graph, eyes, actions.';

type NodeType = 'synthesis' | 'citation' | 'derivation' | 'observation';
type Node = {
  id: string;
  type: NodeType;
  claim: string;
  where?: string;
  source?: string;
  url?: string;
  derives_from?: string[];
};

const nodes: Node[] = [
  {
    id: 'S01-cross-cutting-finish-or-not',
    type: 'synthesis',
    claim: 'Cross-cutting changes finish or they don\'t.',
    where: 'opening',
  },
  {
    id: 'S02-context-in-hand',
    type: 'synthesis',
    claim: 'Every human in the loop has the context they need to act on the change in front of them.',
    where: 'the principle',
  },
  {
    id: 'D03-cascade-loop',
    type: 'derivation',
    claim: 'Skipping the constraint produces Campaign → Stall → Escalate → Directive → New Campaign.',
    derives_from: ['S02-context-in-hand'],
  },
  {
    id: 'S04-three-paths',
    type: 'synthesis',
    claim: 'Three valid responses — automate, centralize, enable.',
    derives_from: ['S02-context-in-hand'],
  },
  {
    id: 'D05-dead-zone',
    type: 'derivation',
    claim: 'The pattern fails in the middle — work done for the team, stop short of merge. Human-in-loop without context.',
    derives_from: ['S02-context-in-hand', 'S04-three-paths'],
  },
  {
    id: 'C01-codemod',
    type: 'citation',
    claim: 'Codemod — a program that rewrites source code mechanically.',
    source: 'facebookarchive/codemod',
    url: 'https://github.com/facebookarchive/codemod',
  },
];

type EyesItem = {
  id: string;
  what: string;
  why: string;
  ground_with?: { label: string; url?: string }[];
};

const eyes: EyesItem[] = [
  {
    id: 'D03-cascade-loop',
    what: 'The cascade loop (Campaign → Stall → Escalate → Directive → New) is the author\'s observation. No external citation naming this exact failure mode.',
    why: 'The pattern is plausible from first-hand engineering experience, but external corroboration would strengthen the claim. Adjacent literature exists.',
    ground_with: [
      { label: 'Brooks\'s law (Mythical Man-Month, 1975)', url: 'https://en.wikipedia.org/wiki/Brooks%27s_law' },
      { label: 'Conway\'s law on org structure → system structure', url: 'https://en.wikipedia.org/wiki/Conway%27s_law' },
    ],
  },
  {
    id: 'S04-three-paths',
    what: 'The three-paths taxonomy (automate / centralize / enable) is original framing. No cited prior taxonomy.',
    why: 'Useful as the author\'s synthesis. If a published org-design taxonomy already names a similar trichotomy, citing it would let the essay sit alongside that frame instead of re-naming it.',
  },
  {
    id: 'D05-dead-zone',
    what: '"Dead zone" is the author\'s naming. No empirical data on how often this specific failure mode occurs in real orgs.',
    why: 'The naming is sharp; the prevalence claim is implicit. An open question: what fraction of stalled cross-cutting initiatives sit in the dead zone vs. fail elsewhere?',
  },
];

type ActionItem = {
  label: string;
  body: string;
  href?: string;
  kind: 'etude' | 'apply' | 'next';
};

const actions: ActionItem[] = [
  {
    kind: 'etude',
    label: 'Cascade simulator',
    body: 'Press launch. Watch four campaigns spawn. The original migration creeps. Demonstrates D03.',
    href: '/etudes/campaign-cascade/cascade-simulator/',
  },
  {
    kind: 'etude',
    label: 'Review this PR',
    body: '30 seconds in the seat where the cascade lands. Demonstrates D05.',
    href: '/etudes/campaign-cascade/review-this-pr/',
  },
  {
    kind: 'etude',
    label: 'Three paths',
    body: 'Pick a path for four scenarios. Drills S04.',
    href: '/etudes/campaign-cascade/three-paths/',
  },
  {
    kind: 'apply',
    label: 'Audit your initiatives',
    body: 'For each cross-cutting initiative your org is running, name which of the three paths it\'s on. Anything you can\'t cleanly assign is in the dead zone.',
  },
  {
    kind: 'apply',
    label: 'Find your dead zone',
    body: 'Which migrations have you done the work for (PRs created) but not finished (other teams holding merge)? That\'s the dead zone. Pull the human out of the place they cannot add value.',
  },
  {
    kind: 'next',
    label: 'Same shape, different domain',
    body: 'The know-thyself series argues the same principle — substrate must match the reader — at a different scale (personal memory in LLM conversations).',
    href: '/puzzles/know-thyself/',
  },
];

const typeMeta: Record<NodeType, { letter: string; label: string; chip: string }> = {
  synthesis: { letter: 'S', label: 'synthesis', chip: 'chip-emg' },
  citation: { letter: 'C', label: 'citation', chip: 'chip-eqv' },
  derivation: { letter: 'D', label: 'derivation', chip: 'chip-ovl' },
  observation: { letter: 'O', label: 'observation', chip: 'chip-obs' },
};

const counts = nodes.reduce(
  (acc, n) => {
    acc[n.type] = (acc[n.type] || 0) + 1;
    return acc;
  },
  {} as Record<NodeType, number>,
);
---
<Base title={`Knowledge dashboard — ${essayTitle}`} description={subtitle}>
  <article class="dash-page">
    <header class="dash-head">
      <p class="dash-kicker">Knowledge dashboard</p>
      <h1 class="dash-title">{essayTitle}</h1>
      <p class="dash-relief">{subtitle}</p>
      <nav class="dash-back">
        <a href={`/puzzles/${slug}/`}>← essay</a>
      </nav>
    </header>

    <nav class="tabbar" role="tablist">
      <button type="button" data-tab="graph" class="active" role="tab" aria-selected="true">Graph</button>
      <button type="button" data-tab="eyes" role="tab" aria-selected="false">Eyes <span class="tab-count">{eyes.length}</span></button>
      <button type="button" data-tab="actions" role="tab" aria-selected="false">Actions <span class="tab-count">{actions.length}</span></button>
    </nav>

    <section id="tab-graph" class="tab-panel active" role="tabpanel">
      <p class="tab-lead">The essay's claims, typed and connected. <strong>S</strong>ynthesis is the author's contribution. <strong>C</strong>itation grounds in a named source. <strong>D</strong>erivation follows from prior nodes. Click any node to jump to its card.</p>

      <div class="graph-viz">
        <svg viewBox="0 0 600 380" role="img" aria-label="Knowledge graph — campaign cascade">
          {/* edges first so nodes paint over them */}
          {/* S04 → S02 */}
          <line x1="500" y1="80" x2="300" y2="80" class="edge edge-derives" />
          {/* D03 → S02 */}
          <line x1="175" y1="200" x2="300" y2="80" class="edge edge-derives" />
          {/* D05 → S02 */}
          <line x1="425" y1="200" x2="300" y2="80" class="edge edge-derives" />
          {/* D05 → S04 */}
          <line x1="425" y1="200" x2="500" y2="80" class="edge edge-derives" />

          {/* nodes */}
          <a href="#S01-cross-cutting-finish-or-not" class="viz-node-link">
            <circle cx="100" cy="80" r="26" class="viz-node viz-node-synthesis" />
            <text x="100" y="85" class="viz-node-letter">S</text>
            <text x="100" y="125" class="viz-node-id">S01</text>
          </a>
          <a href="#S02-context-in-hand" class="viz-node-link">
            <circle cx="300" cy="80" r="32" class="viz-node viz-node-synthesis viz-node-spine" />
            <text x="300" y="85" class="viz-node-letter">S</text>
            <text x="300" y="130" class="viz-node-id">S02 · principle</text>
          </a>
          <a href="#S04-three-paths" class="viz-node-link">
            <circle cx="500" cy="80" r="26" class="viz-node viz-node-synthesis" />
            <text x="500" y="85" class="viz-node-letter">S</text>
            <text x="500" y="125" class="viz-node-id">S04</text>
          </a>
          <a href="#D03-cascade-loop" class="viz-node-link">
            <circle cx="175" cy="200" r="26" class="viz-node viz-node-derivation" />
            <text x="175" y="205" class="viz-node-letter">D</text>
            <text x="175" y="245" class="viz-node-id">D03</text>
          </a>
          <a href="#D05-dead-zone" class="viz-node-link">
            <circle cx="425" cy="200" r="26" class="viz-node viz-node-derivation" />
            <text x="425" y="205" class="viz-node-letter">D</text>
            <text x="425" y="245" class="viz-node-id">D05</text>
          </a>
          <a href="#C01-codemod" class="viz-node-link">
            <circle cx="300" cy="310" r="22" class="viz-node viz-node-citation" />
            <text x="300" y="315" class="viz-node-letter">C</text>
            <text x="300" y="350" class="viz-node-id">C01</text>
          </a>
        </svg>
      </div>

      <div class="dash-counts">
        {(Object.keys(counts) as NodeType[]).map((t) => (
          <span class={`chip ${typeMeta[t].chip}`}>
            {typeMeta[t].letter}
            <span class="chip-count"> {counts[t]}</span>
          </span>
        ))}
      </div>

      <div class="graph-nodes">
        {nodes.map((n) => (
          <article class={`graph-node graph-node-${n.type}`} id={n.id}>
            <p class="graph-node-head">
              <span class={`chip ${typeMeta[n.type].chip}`}>{typeMeta[n.type].letter}</span>
              <code class="graph-node-id">{n.id}</code>
              {n.where && <span class="graph-node-where">· {n.where}</span>}
            </p>
            <p class="graph-node-claim">{n.claim}</p>
            {n.source && (
              <p class="graph-node-source">
                <span class="graph-node-edge-label">grounds:</span>{' '}
                {n.url ? <a href={n.url} rel="noopener">{n.source}</a> : <span>{n.source}</span>}
              </p>
            )}
            {n.derives_from && n.derives_from.length > 0 && (
              <p class="graph-node-derives">
                <span class="graph-node-edge-label">derives_from:</span>{' '}
                {n.derives_from.map((d, i) => (
                  <>
                    {i > 0 && ', '}
                    <a href={`#${d}`}><code>{d}</code></a>
                  </>
                ))}
              </p>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="tab-eyes" class="tab-panel" role="tabpanel">
      <p class="tab-lead">Claims that need more grounding. The essay's confident synthesis — but where external corroboration would strengthen the case, or an open question is implicit.</p>

      <div class="eyes-list">
        {eyes.map((e) => (
          <article class="eyes-item">
            <p class="eyes-item-head">
              <a href={`#${e.id}`} class="eyes-item-id"><code>{e.id}</code></a>
            </p>
            <p class="eyes-what">{e.what}</p>
            <p class="eyes-why"><em>Why eyes:</em> {e.why}</p>
            {e.ground_with && e.ground_with.length > 0 && (
              <p class="eyes-ground">
                <span class="eyes-ground-label">ground_with:</span>
                <ul>
                  {e.ground_with.map((g) => (
                    <li>
                      {g.url ? <a href={g.url} rel="noopener">{g.label}</a> : <span>{g.label}</span>}
                    </li>
                  ))}
                </ul>
              </p>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="tab-actions" class="tab-panel" role="tabpanel">
      <p class="tab-lead">What the essay implies for the reader. Etudes drill specific claims; <em>apply</em> items put the principle to work; <em>next</em> points at sibling essays.</p>

      <div class="actions-list">
        {actions.map((a) => (
          <article class={`actions-item actions-item-${a.kind}`}>
            <p class="actions-item-head">
              <span class={`actions-kind actions-kind-${a.kind}`}>{a.kind}</span>
              {a.href ? (
                <a href={a.href} class="actions-item-label">{a.label} →</a>
              ) : (
                <span class="actions-item-label">{a.label}</span>
              )}
            </p>
            <p class="actions-item-body">{a.body}</p>
          </article>
        ))}
      </div>
    </section>
  </article>
</Base>

<script is:inline>
  document.querySelectorAll('.tabbar [data-tab]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const name = btn.getAttribute('data-tab');
      document.querySelectorAll('.tabbar [data-tab]').forEach((b) => {
        const active = b.getAttribute('data-tab') === name;
        b.classList.toggle('active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      document.querySelectorAll('.tab-panel').forEach((p) => {
        p.classList.toggle('active', p.id === 'tab-' + name);
      });
    });
  });

  // Deep-link via hash: #tab-eyes / #tab-actions / #tab-graph
  const hash = window.location.hash.replace('#', '');
  if (hash.startsWith('tab-')) {
    const name = hash.slice(4);
    const btn = document.querySelector(`.tabbar [data-tab="${name}"]`);
    if (btn) btn.click();
  }
  // Node click in viz → switch back to graph tab if needed, then anchor handles it
  document.querySelectorAll('.viz-node-link').forEach((a) => {
    a.addEventListener('click', () => {
      const graphBtn = document.querySelector('.tabbar [data-tab="graph"]');
      if (graphBtn && !graphBtn.classList.contains('active')) graphBtn.click();
    });
  });
</script>

<style is:global>
  .dash-page {
    max-width: 44rem;
    margin: 0 auto;
  }
  .dash-head {
    margin-bottom: 1.5rem;
  }
  .dash-kicker {
    font-family: var(--sans);
    font-size: var(--label-size);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin: 0 0 0.6rem;
  }
  .dash-title {
    font-family: var(--serif-display);
    font-size: 1.75rem;
    line-height: 1.2;
    margin: 0 0 0.35rem;
    letter-spacing: -0.005em;
  }
  .dash-relief {
    font-family: var(--serif);
    font-style: italic;
    color: var(--muted);
    font-size: 0.98rem;
    margin: 0 0 0.85rem;
    line-height: 1.5;
  }
  .dash-back {
    font-family: var(--sans);
    font-size: 0.85rem;
  }
  .dash-back a { color: var(--muted); text-decoration: none; }
  .dash-back a:hover { color: var(--accent); }

  /* === tabbar === */
  .tabbar {
    display: flex;
    gap: 0.4rem;
    margin: 1.5rem 0 1.5rem;
    padding: 0.3rem;
    background: var(--bg-soft);
    border-radius: 999px;
    width: fit-content;
  }
  .tabbar button {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--muted);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 240ms ease, color 240ms ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .tabbar button:hover {
    color: var(--text);
  }
  .tabbar button.active {
    background: var(--text);
    color: var(--bg);
  }
  .tabbar button.active:hover {
    color: var(--bg);
  }
  .tab-count {
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    opacity: 0.7;
  }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
  .tab-lead {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 1.5rem;
    font-style: italic;
  }

  /* === Graph tab — SVG viz === */
  .graph-viz {
    margin: 0 0 1.75rem;
    padding: 1rem;
    background: var(--bg-soft);
    border-radius: 12px;
    overflow: hidden;
  }
  .graph-viz svg {
    display: block;
    width: 100%;
    height: auto;
    max-height: 380px;
  }
  .edge {
    stroke: var(--line);
    stroke-width: 1.5;
    fill: none;
    transition: stroke 200ms ease, stroke-width 200ms ease;
  }
  .edge-derives {
    stroke-dasharray: 4 3;
  }
  .viz-node-link {
    cursor: pointer;
    text-decoration: none;
  }
  .viz-node {
    transition: transform 180ms ease, filter 180ms ease;
    transform-origin: center;
    transform-box: fill-box;
  }
  .viz-node-link:hover .viz-node {
    filter: brightness(1.08) drop-shadow(0 2px 6px rgba(40,30,20,0.18));
  }
  .viz-node-synthesis {
    fill: #c9a98e;
    stroke: #8a6b50;
    stroke-width: 1.5;
  }
  .viz-node-spine {
    stroke-width: 2.5;
    stroke: var(--accent);
  }
  .viz-node-derivation {
    fill: #b8c4a8;
    stroke: #6f7d5f;
    stroke-width: 1.5;
  }
  .viz-node-citation {
    fill: #9eb3b8;
    stroke: #5e7479;
    stroke-width: 1.5;
  }
  .viz-node-letter {
    fill: #fffdf7;
    font-family: var(--sans);
    font-size: 16px;
    font-weight: 700;
    text-anchor: middle;
    pointer-events: none;
  }
  .viz-node-id {
    fill: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    text-anchor: middle;
    pointer-events: none;
  }

  /* === Graph tab — node cards === */
  .dash-counts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    padding: 0.85rem 1rem;
    background: var(--bg-soft);
    border-radius: 10px;
  }
  .dash-counts .chip {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.55rem;
  }
  .chip-count {
    font-family: var(--sans);
    font-size: 0.85rem;
    color: var(--muted);
    margin-left: 0.35rem;
    font-weight: 500;
  }
  .graph-nodes {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .graph-node {
    background: var(--bg-soft);
    border-radius: 10px;
    padding: 1rem 1.15rem;
    scroll-margin-top: 1rem;
  }
  .graph-node:target {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .graph-node-head {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 0.45rem;
    flex-wrap: wrap;
  }
  .graph-node-id {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    color: var(--muted);
    background: transparent;
    padding: 0;
  }
  .graph-node-where {
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--muted);
    font-style: italic;
  }
  .graph-node-claim {
    margin: 0 0 0.55rem;
    line-height: 1.55;
    color: var(--text);
  }
  .graph-node-source,
  .graph-node-derives {
    margin: 0.3rem 0 0;
    font-family: var(--sans);
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .graph-node-edge-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    color: var(--accent);
    margin-right: 0.15rem;
  }
  .graph-node-source a,
  .graph-node-derives a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--line);
    text-underline-offset: 2px;
  }
  .graph-node-source a:hover,
  .graph-node-derives a:hover {
    text-decoration-color: var(--accent);
  }
  .graph-node-derives code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    background: transparent;
    padding: 0;
  }

  /* === Eyes tab === */
  .eyes-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .eyes-item {
    background: var(--bg-soft);
    border-radius: 10px;
    padding: 1rem 1.15rem;
    border-left: 3px solid var(--accent);
  }
  .eyes-item-head {
    margin: 0 0 0.5rem;
  }
  .eyes-item-id code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
    color: var(--muted);
    background: transparent;
  }
  .eyes-item-id {
    text-decoration: none;
  }
  .eyes-item-id:hover code {
    color: var(--accent);
  }
  .eyes-what {
    margin: 0 0 0.5rem;
    line-height: 1.55;
  }
  .eyes-why {
    margin: 0 0 0.5rem;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .eyes-ground {
    margin: 0.6rem 0 0;
  }
  .eyes-ground-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    color: var(--accent);
    margin-right: 0.25rem;
  }
  .eyes-ground ul {
    margin: 0.3rem 0 0 0;
    padding-left: 1.25rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .eyes-ground li {
    color: var(--muted);
  }
  .eyes-ground a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--line);
    text-underline-offset: 2px;
  }
  .eyes-ground a:hover {
    text-decoration-color: var(--accent);
  }

  /* === Actions tab === */
  .actions-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .actions-item {
    background: var(--bg-soft);
    border-radius: 10px;
    padding: 1rem 1.15rem;
  }
  .actions-item-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin: 0 0 0.4rem;
    flex-wrap: wrap;
  }
  .actions-kind {
    font-family: var(--sans);
    font-size: var(--label-size);
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    color: var(--muted);
    background: var(--bg);
  }
  .actions-kind-etude { color: var(--accent); }
  .actions-kind-apply { color: var(--text); }
  .actions-kind-next { color: var(--muted); }
  .actions-item-label {
    font-family: var(--serif);
