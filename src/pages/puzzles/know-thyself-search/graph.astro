---
import Base from '../../../layouts/Base.astro';
import GraphNode from '../../../components/GraphNode.astro';
import IssueLink from '../../../components/IssueLink.astro';

const slug = 'know-thyself-search';
const essayTitle = 'Search was never about humans';
const subtitle = 'The essay\'s knowledge, dashboard-shaped — graph, eyes, actions.';

type NodeType = 'synthesis' | 'citation' | 'derivation' | 'observation';
type Node = {
  id: string;
  type: NodeType;
  claim: string;
  where?: string;
  source?: string;
  url?: string;
  derives_from?: string[];
  why?: string;
};

const nodes: Node[] = [
  {
    id: 'S01-search-one-shape',
    type: 'synthesis',
    claim: 'Search has always been one shape: graph-traversal-with-ranking — find relevant nodes by walking edges, ranked by some distance function.',
    where: 'the spine',
    why: 'The load-bearing claim. Every scale below is the same shape with constants reset — node spec, edge spec, query format, reader.',
  },
  {
    id: 'C01-salton-1968',
    type: 'citation',
    claim: 'Salton 1968, Automatic Information Organization and Retrieval — set the original shape; vector-space-model named the geometry (Salton, Wong, Yang 1975).',
    source: 'Salton, Automatic Information Organization and Retrieval (1968)',
    why: 'Grounds the spine in the field\'s founding text. The shape did not start with the web; it started with text retrieval at IBM.',
  },
  {
    id: 'C02-pagerank-1998',
    type: 'citation',
    claim: 'Brin & Page 1998, PageRank — added link-graph priors to the ranking function.',
    source: 'Brin & Page, The Anatomy of a Large-Scale Hypertextual Web Search Engine (1998)',
    url: 'http://infolab.stanford.edu/~backrub/google.html',
    why: 'The second canonical citation in the spine\'s genealogy. Showed ranking by what other nodes point at — an early move toward provenance-aware retrieval.',
  },
  {
    id: 'S02-scale-1-inverted-index',
    type: 'synthesis',
    claim: 'Scale 1 — Inverted index (Lucene, BM25/TF-IDF). Terms ↔ documents, weighted by frequency. Reader: human. Format: ten ranked links.',
    where: 'four scales · §2',
    derives_from: ['S01-search-one-shape'],
    why: 'The first instance of the spine. Two-word query, short walk, ranking by overlap. Still alive at Lucene scale because the shape is correct — only the constants are old.',
  },
  {
    id: 'S03-scale-2-vector-retrieval',
    type: 'synthesis',
    claim: 'Scale 2 — Vector retrieval. Embeddings as nodes; cosine as edge; HNSW as the index that becomes a graph itself. Reader: human or LLM.',
    where: 'four scales · §2',
    derives_from: ['S01-search-one-shape'],
    why: 'The node specification flips from word to embedding. Same walk; same ranking; new geometry. The index itself is a small-world graph — the spine recurses.',
  },
  {
    id: 'C03-hnsw-2018',
    type: 'citation',
    claim: 'Malkov & Yashunin 2018 — Hierarchical Navigable Small World graphs. The index that makes vector lookup log-time at scale.',
    source: 'Malkov & Yashunin, Hierarchical Navigable Small World graphs (2018)',
    url: 'https://arxiv.org/abs/1603.09320',
    why: 'Names the data structure that makes Scale 2 work past ten thousand vectors. Below that, brute-force matmul wins — a load-bearing scale-dependence the essay returns to.',
  },
  {
    id: 'S04-scale-3-typed-graph',
    type: 'synthesis',
    claim: 'Scale 3 — Typed knowledge graph. Nodes are claims, not documents; edges are labelled (grounds, derives_from, contradicts). Reader: a self or its agent.',
    where: 'four scales · §2',
    derives_from: ['S01-search-one-shape'],
    why: 'The labels stop being decoration and start doing retrieval work — distinguishing said-five-times from independently-grounded-twice. Where attribution-≠-confidence enters the index.',
  },
  {
    id: 'S05-scale-4-ai-native',
    type: 'synthesis',
    claim: 'Scale 4 — AI-native search. Query is a declarative sentence shaped like the answer; results are atomic chunks with provenance. Reader: an agent.',
    where: 'four scales · §2',
    derives_from: ['S01-search-one-shape'],
    why: 'The reader changes again. Filter first, then rank. Comprehensiveness, recency, type-correctness, provenance-strength replace popularity. The retriever spawns retrievers.',
  },
  {
    id: 'S06-bounded-context-forces-graph',
    type: 'synthesis',
    claim: 'Bounded context forces structured memory. When |K| exceeds C_n, lossless compression hits Shannon\'s floor; factoring into typed nodes is the only operation that scales.',
    where: 'the necessity argument · §3',
    derives_from: ['S01-search-one-shape'],
    why: 'The load-bearing turn. Promotes the four scales from "convenient pattern" to "the only architecture that survives a finite reader." The essay\'s pivot from descriptive to deductive.',
  },
  {
    id: 'C04-bounded-context-stack',
    type: 'citation',
    claim: 'Miller 1956 / Cowan 2001 / Simon / Shannon / Codd — working memory bounded; institutions bounded; lossless compression bounded; factoring is the space-creating operation that doesn\'t lose information.',
    source: 'Miller, Cowan, Simon, Shannon, Codd — the bounded-context stack',
    why: 'Five separate canonical results stacked into one necessity argument. The depth of the stack is what makes "filling the graph, not the context window" deductive rather than a preference.',
  },
  {
    id: 'C05-mccarthy-okg-theorem-4',
    type: 'citation',
    claim: 'McCarthy, open-knowledge-graph — Theorem 4: growing C_n directly does not solve retrieval; the efficient path is filling the graph, not the context window.',
    source: 'McCarthy, open-knowledge-graph',
    url: 'https://github.com/patdmc/open-knowledge-graph',
    why: 'The formal proof for the scientific case the essay extends. Theorem 4 is the line the maximalist context-window race is denying — not failing, denying.',
  },
  {
    id: 'S07-two-query-archetypes',
    type: 'synthesis',
    claim: 'Two query archetypes — humans type two words, agents emit declarative sentences shaped like the answer.',
    where: 'four scales · §2',
    derives_from: ['S02-scale-1-inverted-index', 'S05-scale-4-ai-native'],
    why: 'The reader-shape collapse. Same retrieval problem; opposite query format; the bridge that explains why search APIs built for humans break for agents and vice versa.',
  },
  {
    id: 'D01-same-shape-across-scales',
    type: 'derivation',
    claim: 'The four scales reset constants, not shape. Node spec, edge spec, query format, reader change; graph-traversal-with-ranking does not.',
    where: '§2 close',
    derives_from: ['S02-scale-1-inverted-index', 'S03-scale-2-vector-retrieval', 'S04-scale-3-typed-graph', 'S05-scale-4-ai-native'],
    why: 'The cross-scale claim — the essay\'s synthesis. Once the four scales are listed, the invariant pops out as a derivation, not a posit.',
  },
  {
    id: 'S08-deepseek-v4-postscript',
    type: 'synthesis',
    claim: 'Postscript — DeepSeek V4. Hybrid sparse + heavily-compressed attention at 7–10% of V3.2 KV cache: graph-traversal-with-ranking internalized one further. The reader is the model.',
    where: 'postscript · Apr 26 2026',
    derives_from: ['S05-scale-4-ai-native', 'S06-bounded-context-forces-graph'],
    why: 'The shape recurses inside the model. Tokens become nodes; sparse attention becomes a walk; compression becomes ranking. McCarthy\'s "fill the graph" applied to weights.',
  },
  {
    id: 'C06-turnbull-metadata',
    type: 'citation',
    claim: 'Turnbull, Metadata: the 3rd kind of retrieval (Apr 21 2026) — agents query by attribute; metadata is the retrieval kind lexical and embedding both miss.',
    source: 'Turnbull, Metadata: the 3rd kind of retrieval',
    url: 'https://softwaredoug.com/blog/2026/04/21/metadata-the-3rd-kind-of-retrieval',
    why: 'External corroboration for the third axis at Scale 4 — what something is, not just what it looks like or means. Names a retrieval kind the four-scales taxonomy depends on.',
  },
  {
    id: 'C07-turnbull-agents',
    type: 'citation',
    claim: 'Turnbull, Can agents replace the search stack? (Apr 28 2026) — agents add value on entity-discovery; add nothing on information-discovery, because if they knew what was correct they would not need search.',
    source: 'Turnbull, Can agents replace the search stack?',
    url: 'https://softwaredoug.com/blog/2026/04/28/search-apis-replaced-by-agents.html',
    why: 'The closing limit. Sharpens what the agent reader can and cannot do — and so what the publisher must still ship as ground truth.',
  },
];

type EyesItem = {
  id: string;
  what: string;
  why: string;
  ground_with?: { label: string; url?: string }[];
};

const eyes: EyesItem[] = [
  {
    id: 'D01-same-shape-across-scales',
    what: 'The cross-scale "same shape, four times" claim is the author\'s synthesis. No external source names this exact invariance — graph-traversal-with-ranking across inverted index, vector retrieval, typed graph, and AI-native search.',
    why: 'Adjacent literature names the pieces (Bryk on Scale 4, Lù et al. on agent web, McCarthy on Scale 3) but stops short of the cross-scale invariant. The synthesis is plausible from first-hand engineering, but external corroboration would let it sit alongside named prior work.',
    ground_with: [
      { label: 'Bryk, Why Google Search Sucks for AI', url: 'https://jxnl.co/writing/2025/09/11/why-google-search-sucks-for-ai-will-bryk-exa/' },
      { label: 'Lù et al., Build the Web for Agents', url: 'https://arxiv.org/abs/2506.10953' },
      { label: 'Scale-invariance / fractal data structures in DB & IR literature' },
    ],
  },
  {
    id: 'C05-mccarthy-okg-theorem-4',
    what: '"Fill the graph, not the context window" is the central technical wager. McCarthy proves it for the scientific case; the essay extends it to personal-memory and agent-retrieval without the same selection pressure.',
    why: 'The wager hinges on long-context degradation as |K| grows. Empirical needle-in-haystack and lost-in-the-middle results corroborate the direction, but the exact crossover where graph retrieval beats raw context for a typed-personal-graph at the scale this essay names has not been benchmarked.',
    ground_with: [
      { label: 'Liu et al., Lost in the Middle (long-context degradation)', url: 'https://arxiv.org/abs/2307.03172' },
      { label: 'Anthropic, Claude needle-in-haystack benchmarks', url: 'https://www.anthropic.com/news/claude-2-1-prompting' },
      { label: 'McCarthy, open-knowledge-graph — Theorem 4 (scientific case)', url: 'https://github.com/patdmc/open-knowledge-graph' },
    ],
  },
  {
    id: 'S04-scale-3-typed-graph',
    what: 'The personal-graph rewrites of McCarthy — `valid_at` / confidence-decay, inverted edge-density, K-without-A — are extrapolations. McCarthy proves necessity arguments under selection-under-competition; personal-memory has none of those pressures.',
    why: 'The personal case has not been empirically tested at scale. A forty-year-old\'s graph being node-dense with sparse adjacency is a plausible introspective claim, not a measured property of n personal graphs.',
    ground_with: [
      { label: 'Episodic vs semantic memory literature (Tulving 1972)' },
      { label: 'Aging and autobiographical memory empirical results' },
    ],
  },
  {
    id: 'S08-deepseek-v4-postscript',
    what: 'The DeepSeek V4 postscript bridges hardware-level memory architecture (KV cache, sparse attention) to retrieval-as-attention as one further scale of graph-traversal-with-ranking. The bridge is suggestive, not benchmarked.',
    why: 'The 7–10% KV-cache figure is real; the framing of compressed attention as "graph-traversal-with-ranking internalized" is the author\'s. A direct benchmark — DeepSeek V4 long-context retrieval vs typed-graph retrieval at equivalent token counts — would let the postscript pay its own bill.',
    ground_with: [
      { label: 'DeepSeek V4 release notes', url: 'https://huggingface.co/blog/deepseekv4' },
      { label: 'Compressed Sparse Attention (CSA) papers' },
    ],
  },
  {
    id: 'S07-two-query-archetypes',
    what: '"Humans type two words, agents emit declarative sentences" is the author\'s framing, well-aligned with Exa\'s training data on link-anchor citations but not yet a published taxonomy.',
    why: 'The query-format split is the load-bearing reason agent search and human search diverge — but the claim would be stronger with measured query-length distributions across human SERPs vs agent tool-call corpora.',
    ground_with: [
      { label: 'Exa training corpus / link-prediction objective', url: 'https://www.latent.space/p/exa' },
    ],
  },
];

type ActionItem = {
  label: string;
  body: string;
  href?: string;
  kind: 'etude' | 'apply' | 'next';
};

const actions: ActionItem[] = [
  {
    kind: 'etude',
    label: 'Two queries',
    body: 'Type a human two-word query, then an agent declarative sentence; watch the retriever rank differently. Drills S07.',
    href: '/etudes/know-thyself/two-queries/',
  },
  {
    kind: 'etude',
    label: 'Token budget',
    body: 'Slide the graph size; watch the paste break. The reader is bounded; the corpus is not. Drills S06.',
    href: '/etudes/know-thyself/token-budget/',
  },
  {
    kind: 'apply',
    label: 'Walk a domain through the four scales',
    body: 'Pick a domain you know — your codebase, your docs, your notes. Walk it through Scales 1–4. What\'s indexed today, what\'s vectorized, what\'s typed, what\'s agent-readable? What\'s missing?',
  },
  {
    kind: 'apply',
    label: 'Find your bounded reader',
    body: 'For one corpus you maintain (a wiki, a project, a journal), name the reader and their token budget. If the corpus exceeds it, name the factoring move that would let retrieval scale without degrading.',
  },
  {
    kind: 'apply',
    label: 'Run the demo',
    body: 'Clone know-thyself-search, embed the example graph, run the three retrieval modes side by side. The cosine baseline finds the theme; the type filter finds the episode; the provenance rerank demotes the tentative.',
    href: 'https://github.com/parrik/know-thyself-search',
  },
  {
    kind: 'next',
    label: 'Part I — Know thyself',
    body: 'The opening of the loop. Why a typed personal-knowledge graph is the architecture, before retrieval enters.',
    href: '/puzzles/know-thyself/',
  },
  {
    kind: 'next',
    label: 'Part III — Security was never about response',
    body: 'Same shape, third surface. Security as gates at boundaries — the same deny-by-default, type-first pattern applied to a different domain.',
    href: '/puzzles/know-thyself-security/',
  },
];

const typeMeta: Record<NodeType, { letter: string; label: string; chip: string }> = {
  synthesis: { letter: 'S', label: 'synthesis', chip: 'chip-emg' },
  citation: { letter: 'C', label: 'citation', chip: 'chip-eqv' },
  derivation: { letter: 'D', label: 'derivation', chip: 'chip-ovl' },
  observation: { letter: 'O', label: 'observation', chip: 'chip-obs' },
};

const counts = nodes.reduce(
  (acc, n) => {
    acc[n.type] = (acc[n.type] || 0) + 1;
    return acc;
  },
  {} as Record<NodeType, number>,
);

type NodePos = { cx: number; cy: number; r: number; labelY: number; labelText: string };
const positions: Record<string, NodePos> = {
  // spine
  'S01-search-one-shape':            { cx: 360, cy: 260, r: 34, labelY: 312, labelText: 'S01 · spine' },
  // four scales at diagonals (NW, NE, SE, SW)
  'S02-scale-1-inverted-index':      { cx: 260, cy: 170, r: 28, labelY: 215, labelText: 'S02 · scale 1' },
  'S03-scale-2-vector-retrieval':    { cx: 460, cy: 170, r: 28, labelY: 215, labelText: 'S03 · scale 2' },
  'S04-scale-3-typed-graph':         { cx: 460, cy: 350, r: 28, labelY: 395, labelText: 'S04 · scale 3' },
  'S05-scale-4-ai-native':           { cx: 260, cy: 350, r: 28, labelY: 395, labelText: 'S05 · scale 4' },
  // bounded-context due south, outer
  'S06-bounded-context-forces-graph':{ cx: 360, cy: 460, r: 30, labelY: 506, labelText: 'S06 · necessity' },
  // two-query archetypes — west, between Scale 1 and Scale 4
  'S07-two-query-archetypes':        { cx: 130, cy: 260, r: 24, labelY: 300, labelText: 'S07 · two queries' },
  // DeepSeek postscript — outer SE corner
  'S08-deepseek-v4-postscript':      { cx: 615, cy: 445, r: 24, labelY: 488, labelText: 'S08 · postscript' },
  // same-shape derivation — center-east of spine
  'D01-same-shape-across-scales':    { cx: 595, cy: 260, r: 26, labelY: 304, labelText: 'D01 · invariant' },
  // citations — smaller, outside their grounded synthesis
  'C01-salton-1968':                 { cx: 195, cy: 80,  r: 20, labelY: 118, labelText: 'C01 · Salton' },
  'C02-pagerank-1998':               { cx: 360, cy: 60,  r: 20, labelY: 98,  labelText: 'C02 · PageRank' },
  'C03-hnsw-2018':                   { cx: 580, cy: 90,  r: 20, labelY: 128, labelText: 'C03 · HNSW' },
  'C04-bounded-context-stack':       { cx: 200, cy: 460, r: 22, labelY: 500, labelText: 'C04 · stack' },
  'C05-mccarthy-okg-theorem-4':      { cx: 480, cy: 470, r: 22, labelY: 510, labelText: 'C05 · McCarthy' },
  'C06-turnbull-metadata':           { cx: 130, cy: 400, r: 20, labelY: 438, labelText: 'C06 · Turnbull-1' },
  'C07-turnbull-agents':             { cx: 660, cy: 360, r: 20, labelY: 398, labelText: 'C07 · Turnbull-2' },
};
---
<Base title={`Knowledge dashboard — ${essayTitle}`} description={subtitle}>
  <article class="dash-page">
    <header class="dash-head">
      <p class="dash-kicker">Knowledge dashboard</p>
      <h1 class="dash-title">{essayTitle}</h1>
      <p class="dash-relief">{subtitle}</p>
      <nav class="dash-back">
        <a href={`/puzzles/${slug}/`}>← essay</a>
      </nav>
    </header>

    <nav class="tabbar" role="tablist">
      <button type="button" data-tab="graph" class="active" role="tab" aria-selected="true">Graph</button>
      <button type="button" data-tab="eyes" role="tab" aria-selected="false">Eyes <span class="tab-count">{eyes.length}</span></button>
      <button type="button" data-tab="actions" role="tab" aria-selected="false">Actions <span class="tab-count">{actions.length}</span></button>
    </nav>

    <section id="tab-graph" class="tab-panel active" role="tabpanel">
      <p class="tab-lead">The essay's claims, typed and connected. <strong>S</strong>ynthesis is the author's contribution. <strong>C</strong>itation grounds in a named source. <strong>D</strong>erivation follows from prior nodes. Click any node to jump to its card.</p>

      <div class="graph-viz">
        <svg viewBox="0 0 720 520" role="img" aria-label="Knowledge graph — search was never about humans">
          {/* edges first so nodes paint over them */}
          {/* four scales derive from the spine */}
          <line x1="260" y1="170" x2="360" y2="260" class="edge edge-derives" />
          <line x1="460" y1="170" x2="360" y2="260" class="edge edge-derives" />
          <line x1="460" y1="350" x2="360" y2="260" class="edge edge-derives" />
          <line x1="260" y1="350" x2="360" y2="260" class="edge edge-derives" />
          {/* bounded-context derives from the spine (south) */}
          <line x1="360" y1="460" x2="360" y2="260" class="edge edge-derives" />
          {/* two-query archetypes derives from Scale 1 and Scale 4 */}
          <line x1="130" y1="260" x2="260" y2="170" class="edge edge-derives" />
          <line x1="130" y1="260" x2="260" y2="350" class="edge edge-derives" />
          {/* same-shape derivation: from all four scales */}
          <line x1="595" y1="260" x2="460" y2="170" class="edge edge-derives" />
          <line x1="595" y1="260" x2="460" y2="350" class="edge edge-derives" />
          <line x1="595" y1="260" x2="260" y2="170" class="edge edge-derives" />
          <line x1="595" y1="260" x2="260" y2="350" class="edge edge-derives" />
          {/* DeepSeek postscript derives from Scale 4 + bounded-context */}
          <line x1="615" y1="445" x2="260" y2="350" class="edge edge-derives" />
          <line x1="615" y1="445" x2="360" y2="460" class="edge edge-derives" />
          {/* citations ground their nearest synthesis (solid edges) */}
          <line x1="195" y1="80"  x2="360" y2="260" class="edge" />
          <line x1="360" y1="60"  x2="360" y2="260" class="edge" />
          <line x1="580" y1="90"  x2="460" y2="170" class="edge" />
          <line x1="200" y1="460" x2="360" y2="460" class="edge" />
          <line x1="480" y1="470" x2="360" y2="460" class="edge" />
          <line x1="130" y1="400" x2="260" y2="350" class="edge" />
          <line x1="660" y1="360" x2="615" y2="445" class="edge" />

          {nodes.map((n) => {
            const p = positions[n.id];
            if (!p) return null;
            return (
              <GraphNode
                type={n.type}
                cx={p.cx}
                cy={p.cy}
                r={p.r}
                isSpine={n.id === 'S01-search-one-shape'}
                id={n.id}
                claim={n.claim}
                why={n.why}
                where={n.where}
                label={p.labelText}
                letter={typeMeta[n.type].letter}
                typeLabel={typeMeta[n.type].label}
                labelY={p.labelY}
              />
            );
          })}
        </svg>
        <div id="viz-tooltip" class="viz-tooltip" aria-hidden="true"></div>
      </div>

      <div class="dash-counts">
        {(Object.keys(counts) as NodeType[]).map((t) => (
          <span class={`chip ${typeMeta[t].chip}`}>
            {typeMeta[t].letter}
            <span class="chip-count"> {counts[t]}</span>
          </span>
        ))}
      </div>

      <div class="graph-nodes">
        {nodes.map((n) => (
          <article class={`graph-node graph-node-${n.type}`} id={n.id}>
            <p class="graph-node-head">
              <span class={`chip ${typeMeta[n.type].chip}`}>{typeMeta[n.type].letter}</span>
              <code class="graph-node-id">{n.id}</code>
              {n.where && <span class="graph-node-where">· {n.where}</span>}
            </p>
            <p class="graph-node-claim">{n.claim}</p>
            {n.source && (
              <p class="graph-node-source">
                <span class="graph-node-edge-label">grounds:</span>{' '}
                {n.url ? <a href={n.url} rel="noopener">{n.source}</a> : <span>{n.source}</span>}
              </p>
            )}
            {n.derives_from && n.derives_from.length > 0 && (
              <p class="graph-node-derives">
                <span class="graph-node-edge-label">derives_from:</span>{' '}
                {n.derives_from.map((d, i) => (
                  <>
                    {i > 0 && ', '}
                    <a href={`#${d}`}><code>{d}</code></a>
                  </>
                ))}
              </p>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="tab-eyes" class="tab-panel" role="tabpanel">
      <p class="tab-lead">Claims that need more grounding. The essay's confident synthesis — but where external corroboration would strengthen the case, or an open question is implicit.</p>

      <div class="eyes-list">
        {eyes.map((e) => (
          <article class="eyes-item">
            <p class="eyes-item-head">
              <a href={`#${e.id}`} class="eyes-item-id"><code>{e.id}</code></a>
            </p>
            <p class="eyes-what">{e.what}</p>
            <p class="eyes-why"><em>Why eyes:</em> {e.why}</p>
            {e.ground_with && e.ground_with.length > 0 && (
              <p class="eyes-ground">
                <span class="eyes-ground-label">ground_with:</span>
                <ul>
                  {e.ground_with.map((g) => (
                    <li>
                      {g.url ? <a href={g.url} rel="noopener">{g.label}</a> : <span>{g.label}</span>}
                    </li>
                  ))}
                </ul>
              </p>
            )}
            <p class="card-cta">
              <IssueLink kind="eyes" slug={slug} item={e} />
            </p>
          </article>
        ))}
      </div>
    </section>

    <section id="tab-actions" class="tab-panel" role="tabpanel">
      <p class="tab-lead">What the essay implies for the reader. Etudes drill specific claims; <em>apply</em> items put the principle to work; <em>next</em> points at sibling essays.</p>

      <div class="actions-list">
        {actions.map((a) => (
          <article class={`actions-item actions-item-${a.kind}`}>
            <p class="actions-item-head">
              <span class={`actions-kind actions-kind-${a.kind}`}>{a.kind}</span>
              {a.href ? (
                <a href={a.href} class="actions-item-label">{a.label} →</a>
              ) : (
                <span class="actions-item-label">{a.label}</span>
              )}
            </p>
            <p class="actions-item-body">{a.body}</p>
            {a.kind === 'apply' && (
              <p class="card-cta">
                <IssueLink kind="apply" slug={slug} item={a} />
              </p>
            )}
          </article>
        ))}
      </div>
    </section>
  </article>
</Base>

<script is:inline>
  document.querySelectorAll('.tabbar [data-tab]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const name = btn.getAttribute('data-tab');
      document.querySelectorAll('.tabbar [data-tab]').forEach((b) => {
        const active = b.getAttribute('data-tab') === name;
        b.classList.toggle('active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      document.querySelectorAll('.tab-panel').forEach((p) => {
        p.classList.toggle('active', p.id === 'tab-' + name);
      });
    });
  });

  // Deep-link via hash: #tab-eyes / #tab-actions / #tab-graph
  const hash = window.location.hash.replace('#', '');
  if (hash.startsWith('tab-')) {
    const name = hash.slice(4);
    const btn = document.querySelector(`.tabbar [data-tab="${name}"]`);
    if (btn) btn.click();
  }
  // Node click in viz → switch back to graph tab if needed, then anchor handles it
  document.querySelectorAll('.viz-node-link').forEach((a) => {
    a.addEventListener('click', () => {
      const graphBtn = document.querySelector('.tabbar [data-tab="graph"]');
      if (graphBtn && !graphBtn.classList.contains('active')) graphBtn.click();
    });
  });

  // Hover tooltip on graph nodes — pattern from /example-graph-full.html
  const tip = document.getElementById('viz-tooltip');
  if (tip) {
    const escape = (s) => String(s || '').replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[c]));

    document.querySelectorAll('.viz-node-link').forEach((a) => {
      a.addEventListener('mouseenter', () => {
        const id = a.getAttribute('data-id');
        const claim = a.getAttribute('data-claim');
        const why = a.getAttribute('data-why');
        const type = a.getAttribute('data-type');
        const where = a.getAttribute('data-where');
        let html = '<div class="vt-type">' + escape(type);
        if (where) html += '<span class="vt-dot">·</span>' + escape(where);
        html += '</div>';
        html += '<div class="vt-id"><code>' + escape(id) + '</code></div>';
        html += '<div class="vt-claim">' + escape(claim) + '</div>';
        if (why) html += '<div class="vt-why"><span class="vt-label">Why this node:</span> ' + escape(why) + '</div>';
        tip.innerHTML = html;
        tip.classList.add('visible');
      });
      a.addEventListener('mouseleave', () => tip.classList.remove('visible'));
      a.addEventListener('mousemove', (e) => {
        const pad = 12;
        const margin = 6;
        const w = tip.offsetWidth || 280;
        const h = tip.offsetHeight || 100;
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        let x = e.clientX + pad;
        if (x + w > vw - margin) x = e.clientX - w - pad;
        if (x < margin) x = margin;
        if (x + w > vw - margin) x = vw - w - margin;
        let y = e.clientY + pad;
        if (y + h > vh - margin) y = e.clientY - h - pad;
        if (y < margin) y = margin;
        tip.style.left = x + 'px';
        tip.style.top = y + 'px';
      });
    });
  }
</script>

