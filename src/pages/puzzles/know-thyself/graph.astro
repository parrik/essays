---
import Base from '../../../layouts/Base.astro';
import GraphNode from '../../../components/GraphNode.astro';
import IssueLink from '../../../components/IssueLink.astro';

const slug = 'know-thyself';
const essayTitle = 'A self was never flat';
const subtitle = 'The essay\'s knowledge, dashboard-shaped — graph, eyes, actions.';

type NodeType = 'synthesis' | 'citation' | 'derivation' | 'observation';
type Node = {
  id: string;
  type: NodeType;
  claim: string;
  where?: string;
  source?: string;
  url?: string;
  derives_from?: string[];
  why?: string;
};

const nodes: Node[] = [
  {
    id: 'S01-mirror-problem',
    type: 'synthesis',
    claim: 'Flat memory turns repetition into evidence — the model speaks back to the user as a mirror, sycophancy hardened into self-knowledge.',
    where: 'opening (Alex case)',
    why: 'Names the failure mode the essay refuses to soften. Six self-diagnoses on a list read as six pieces of evidence; this is the misreading every downstream claim must prevent.',
  },
  {
    id: 'C06-mirror-study',
    type: 'citation',
    claim: 'Condensed user-profile memory produced the largest sycophancy amplification of any personalization feature studied — measured effect, not metaphor.',
    source: 'MIT & Penn State, Personalization features can make LLMs more agreeable (CHI 2026)',
    url: 'https://news.mit.edu/2026/personalization-features-can-make-llms-more-agreeable-0218',
    why: 'Grounds the mirror problem empirically. Without this, the opening is a vivid anecdote; with it, the failure mode is a measured deployment finding.',
  },
  {
    id: 'S02-fix-is-shape',
    type: 'synthesis',
    claim: 'The fix is not more memory. The fix is shape.',
    where: 'turn (after Alex)',
    why: 'The load-bearing claim. The whole essay derives from this pivot — that adding memory cannot undo the mirror because the bug lives in the structure, not the volume.',
    derives_from: ['S01-mirror-problem'],
  },
  {
    id: 'C09-karpathy-wiki',
    type: 'citation',
    claim: 'LLM Wiki — plain markdown, model self-edits, lint loop catches contradictions and orphans. No types, no provenance.',
    source: 'Andrej Karpathy, LLM Wiki (gist, Apr 4 2026)',
    url: 'https://gist.github.com/karpathy',
    why: 'The neighboring proposal that fixes one drift (contradictions) but not the other (repetition-as-evidence). Cited to position the essay\'s claim against the closest live alternative.',
  },
  {
    id: 'S03-memory-must-have-types',
    type: 'synthesis',
    claim: 'Memory must have types — episodic and semantic held in distinct stores, not collapsed into a flat list.',
    where: 'the shape',
    why: 'The first concrete consequence of "fix is shape." Without typed slots, the schema cannot tell said apart from grounded; types are the binding principle.',
    derives_from: ['S02-fix-is-shape'],
  },
  {
    id: 'C04-tulving',
    type: 'citation',
    claim: 'Episodic vs semantic memory as separate stores — the binding principle the schema operationalizes.',
    source: 'Tulving, Episodic and Semantic Memory (1972)',
    why: 'The originating cognitive-psychology distinction the essay\'s eight types refine. Cited to mark the lineage rather than claim novelty for the type/no-type cut.',
  },
  {
    id: 'C05-coala',
    type: 'citation',
    claim: 'Working / episodic / semantic / procedural — the canonical agent-memory taxonomy. The eight node types here are an opinionated refinement of the semantic side.',
    source: 'Sumers, Yao, Narasimhan, Cognitive Architectures for Language Agents (2023)',
    url: 'https://arxiv.org/abs/2309.02427',
    why: 'The contemporary academic frame. Cited to position the eight types as a refinement (not replacement) of CoALA — naming the literature the schema sits inside.',
  },
  {
    id: 'C12-mccarthy-edges',
    type: 'citation',
    claim: 'Edge vocabulary — derives_from, evidences, grounds, overlaps_with, generalizes — each carrying an (attribution, evidence, derivation) triple.',
    source: 'Patrick D. McCarthy, open-knowledge-graph',
    url: 'https://github.com/patdmc/open-knowledge-graph',
    why: 'Provides the edge vocabulary the essay\'s nodes plug into. McCarthy supplies the verbs; the eight types are the nouns. Without this citation, attribution≠confidence reads as the author\'s coinage rather than an adoption.',
  },
  {
    id: 'S07-attribution-neq-confidence',
    type: 'synthesis',
    claim: 'Attribution ≠ confidence. The operating rule.',
    where: 'the rule',
    why: 'The single sentence that does the work. Adopted from McCarthy\'s scientific-knowledge graphs and applied to personal memory — the rule that prevents repetition from masquerading as corroboration.',
    derives_from: ['S03-memory-must-have-types', 'C12-mccarthy-edges'],
  },
  {
    id: 'S08-repetition-isnt-corroboration',
    type: 'synthesis',
    claim: 'Six conversations saying the same thing is one derivation repeated six times, not six pieces of evidence. A novel cannot quietly become an overlap; it waits for a new, independent observation.',
    where: 'the rule, applied',
    why: 'The operational consequence of the rule. This is the discipline the schema enforces structurally — the schema makes repetition-as-evidence impossible by construction.',
    derives_from: ['S07-attribution-neq-confidence'],
  },
  {
    id: 'C10-memanto',
    type: 'citation',
    claim: 'Typed semantic memory with information-theoretic retrieval — thirteen vector categories, no graph; 89.8% on LongMemEval, 87.1% on LoCoMo, beating graph-hybrid baselines on QA recall.',
    source: 'Memanto (arXiv:2604.22085, Apr 23 2026)',
    url: 'https://arxiv.org/abs/2604.22085',
    why: 'The strongest neighboring proposal — types-without-edges wins fact-retrieval benchmarks. Cited honestly: the essay\'s claim is that benchmarks measure recall, not whether one derivation got mistaken for six.',
  },
  {
    id: 'C11-anthropic-memory',
    type: 'citation',
    claim: 'Client-side persistence exposed as a /memories directory the model can view / create / str_replace / insert / delete / rename.',
    source: 'Anthropic memory tool (Apr 8 2026)',
    url: 'https://platform.claude.com/docs/en/agents-and-tools/tool-use/memory-tool',
    why: 'The shipped infrastructure that makes the schema deployable today. Without this, the YAML-graph claim is theoretical; with it, the primitive is already in the field.',
  },
  {
    id: 'S13-graph-is-the-memory',
    type: 'synthesis',
    claim: 'The graph IS the memory. A YAML file the user owns; models read it and pick up the thread; when a model retires, the graph stays.',
    where: 'the punchline',
    why: 'The architectural claim the whole essay points at. The schema outlasts any model because the memory is not in the model — it is a file the user keeps. Privacy, portability, and provenance fall out of this one shape.',
    derives_from: ['C12-mccarthy-edges', 'C11-anthropic-memory'],
  },
];

type EyesItem = {
  id: string;
  what: string;
  why: string;
  ground_with?: { label: string; url?: string }[];
};

const eyes: EyesItem[] = [
  {
    id: 'S03-memory-must-have-types',
    what: 'The eight node types (Reference / Observation / Overlap / Novel / Emergent / Equivalency / Practice / Open) are the author\'s opinionated refinement of CoALA\'s four. The specific cuts — especially Novel, Emergent, Open — are author-original.',
    why: 'CoALA grounds working/episodic/semantic/procedural. The further partition of the semantic side is the essay\'s contribution, not yet validated externally. Empirical work showing these specific cuts reduce one-derivation-as-six errors would harden the case.',
    ground_with: [
      { label: 'CoALA — working/episodic/semantic/procedural', url: 'https://arxiv.org/abs/2309.02427' },
      { label: 'Park et al., Generative Agents (UIST 2023) — observation vs reflection separation' },
      { label: 'A targeted user study on typed-vs-flat memory and sycophancy outcomes' },
    ],
  },
  {
    id: 'S08-repetition-isnt-corroboration',
    what: 'The Mira/Alex case is illustrative, not empirical. No user study cited testing whether graph-shaped memory reduces sycophancy at the user-experience level — only the CHI 2026 paper showing flat memory amplifies it.',
    why: 'The negative result (flat memory amplifies sycophancy) is grounded. The positive result (typed-and-edged memory reduces it) is asserted by construction, not measured. The essay would land harder with a paired study.',
    ground_with: [
      { label: 'CHI 2026 mirror study (the negative case, already cited)', url: 'https://news.mit.edu/2026/personalization-features-can-make-llms-more-agreeable-0218' },
      { label: 'A within-subjects study comparing flat vs typed memory on sycophancy metrics' },
    ],
  },
  {
    id: 'S13-graph-is-the-memory',
    what: 'The architectural claim ("graph IS the memory") rests on two recent shipped/proposed pieces (Anthropic memory tool, McCarthy edge vocabulary). It is a synthesis claim, not yet stress-tested at scale.',
    why: 'The composition is sharp but new. Any production deployment story — even a single user running the YAML graph against a real model over months — would move this from elegant proposal to demonstrated architecture.',
    ground_with: [
      { label: 'Anthropic memory tool docs', url: 'https://platform.claude.com/docs/en/agents-and-tools/tool-use/memory-tool' },
      { label: 'Stateful vs stateless agent architecture surveys' },
      { label: 'A longitudinal case study of one user running know-thyself for ≥6 months' },
    ],
  },
  {
    id: 'C10-memanto',
    what: 'Memanto\'s benchmark wins (89.8% LongMemEval, 87.1% LoCoMo) are dispatched in one sentence: "the benchmark measures recall." That move needs more weight.',
    why: 'A reader sympathetic to vector-only memory will not be convinced by a one-line dismissal. An eyes-item that names the specific benchmark task (multi-hop fact retrieval) and contrasts it with the corroboration-provenance task the essay cares about would close the gap.',
    ground_with: [
      { label: 'LongMemEval task definition', url: 'https://arxiv.org/abs/2410.10813' },
      { label: 'LoCoMo benchmark', url: 'https://arxiv.org/abs/2402.17753' },
    ],
  },
];

type ActionItem = {
  label: string;
  body: string;
  href?: string;
  kind: 'etude' | 'apply' | 'next';
};

const actions: ActionItem[] = [
  {
    kind: 'etude',
    label: 'Six restatements',
    body: 'One claim, said six ways. Watch the flat list count it as six. Watch the typed graph count it as one. Drills S08.',
    href: '/etudes/know-thyself/six-restatements/',
  },
  {
    kind: 'etude',
    label: 'Attribution vs confidence',
    body: 'Sort five claims about Alex by attribution count and by independent-derivation count. The two columns disagree. Drills S07.',
    href: '/etudes/know-thyself/attribution-confidence/',
  },
  {
    kind: 'etude',
    label: 'Flat vs typed',
    body: 'Same set of conversations, two memories. The flat memory reads back a confident self-diagnosis; the typed graph reads back a tentative novel. Demonstrates S02 and S13.',
    href: '/etudes/know-thyself/flat-vs-typed/',
  },
  {
    kind: 'apply',
    label: 'Audit your last LLM conversation',
    body: 'If memory was on, what claims about you did the model state confidently? For each: how many independent episodes ground it, and how many times did you simply restate it? The two counts should not be conflated.',
  },
  {
    kind: 'apply',
    label: 'Find your spine',
    body: 'Of the things you believe about yourself, which three or four observations are load-bearing — referenced by the most downstream claims? Miscoding one of those cascades. Knowing which is which is the work.',
  },
  {
    kind: 'apply',
    label: 'Name your novels',
    body: 'Pick three things you have been quietly believing about yourself. For each, write the single episode it derives from. If you cannot find a second independent episode, the claim is a Novel, not an Overlap. Mark it tentative.',
  },
  {
    kind: 'next',
    label: 'Part II — Search was never about humans',
    body: 'The same schema turned around: when you search, what does the system know about how it knows? Retrieval as the second half of the memory question.',
    href: '/puzzles/know-thyself-search/',
  },
  {
    kind: 'next',
    label: 'Same shape, different domain',
    body: 'How to run a cross-cutting campaign — the same structural argument (substrate must match the reader) at org scale instead of memory scale.',
    href: '/puzzles/the-campaign-cascade/',
  },
];

const typeMeta: Record<NodeType, { letter: string; label: string; chip: string }> = {
  synthesis: { letter: 'S', label: 'synthesis', chip: 'chip-emg' },
  citation: { letter: 'C', label: 'citation', chip: 'chip-eqv' },
  derivation: { letter: 'D', label: 'derivation', chip: 'chip-ovl' },
  observation: { letter: 'O', label: 'observation', chip: 'chip-obs' },
};

const counts = nodes.reduce(
  (acc, n) => {
    acc[n.type] = (acc[n.type] || 0) + 1;
    return acc;
  },
  {} as Record<NodeType, number>,
);

type NodePos = { cx: number; cy: number; r: number; labelY: number; labelText: string };
const positions: Record<string, NodePos> = {
  // Spine — center
  'S13-graph-is-the-memory':         { cx: 350, cy: 240, r: 34, labelY: 295, labelText: 'S13 · spine' },

  // Synthesis pentagon — radius ~140 around center
  'S01-mirror-problem':               { cx: 350, cy: 100, r: 26, labelY: 65,  labelText: 'S01' },
  'S02-fix-is-shape':                 { cx: 483, cy: 196, r: 28, labelY: 158, labelText: 'S02' },
  'S03-memory-must-have-types':       { cx: 432, cy: 354, r: 26, labelY: 395, labelText: 'S03' },
  'S07-attribution-neq-confidence':   { cx: 268, cy: 354, r: 26, labelY: 395, labelText: 'S07' },
  'S08-repetition-isnt-corroboration':{ cx: 217, cy: 196, r: 26, labelY: 158, labelText: 'S08' },

  // Citations — outer ring, near the synthesis they ground
  'C06-mirror-study':                 { cx: 350, cy: 30,  r: 20, labelY: 70,  labelText: 'C06' },
  'C09-karpathy-wiki':                { cx: 605, cy: 130, r: 20, labelY: 168, labelText: 'C09' },
  'C04-tulving':                      { cx: 620, cy: 270, r: 20, labelY: 308, labelText: 'C04' },
  'C05-coala':                        { cx: 555, cy: 415, r: 20, labelY: 453, labelText: 'C05' },
  'C10-memanto':                      { cx: 145, cy: 415, r: 20, labelY: 453, labelText: 'C10' },
  'C12-mccarthy-edges':               { cx: 80,  cy: 270, r: 20, labelY: 308, labelText: 'C12' },
  'C11-anthropic-memory':             { cx: 95,  cy: 130, r: 20, labelY: 168, labelText: 'C11' },
};
---
<Base title={`Knowledge dashboard — ${essayTitle}`} description={subtitle}>
  <article class="dash-page">
    <header class="dash-head">
      <p class="dash-kicker">Knowledge dashboard</p>
      <h1 class="dash-title">{essayTitle}</h1>
      <p class="dash-relief">{subtitle}</p>
      <nav class="dash-back">
        <a href={`/puzzles/${slug}/`}>← essay</a>
      </nav>
    </header>

    <nav class="tabbar" role="tablist">
      <button type="button" data-tab="graph" class="active" role="tab" aria-selected="true">Graph</button>
      <button type="button" data-tab="eyes" role="tab" aria-selected="false">Eyes <span class="tab-count">{eyes.length}</span></button>
      <button type="button" data-tab="actions" role="tab" aria-selected="false">Actions <span class="tab-count">{actions.length}</span></button>
    </nav>

    <section id="tab-graph" class="tab-panel active" role="tabpanel">
      <p class="tab-lead">The essay's claims, typed and connected. <strong>S</strong>ynthesis is the author's contribution. <strong>C</strong>itation grounds in a named source. <strong>D</strong>erivation follows from prior nodes. The spine — <em>graph IS the memory</em> — sits at center; everything orbits it. Click any node to jump to its card.</p>

      <div class="graph-viz">
        <svg viewBox="0 0 700 480" role="img" aria-label="Knowledge graph — know thyself">
          {/* edges first so nodes paint over them */}

          {/* S01 → S02 (fix is shape derives from mirror problem) */}
          <line x1="350" y1="100" x2="483" y2="196" class="edge edge-derives" />
          {/* S02 → S03 (types derive from fix is shape) */}
          <line x1="483" y1="196" x2="432" y2="354" class="edge edge-derives" />
          {/* S03 → S07 (attribution≠confidence derives from types) */}
          <line x1="432" y1="354" x2="268" y2="354" class="edge edge-derives" />
          {/* C12 → S07 (McCarthy grounds attribution≠confidence) */}
          <line x1="80"  y1="270" x2="268" y2="354" class="edge edge-derives" />
          {/* S07 → S08 (repetition isn't corroboration derives from attribution≠confidence) */}
          <line x1="268" y1="354" x2="217" y2="196" class="edge edge-derives" />
          {/* C12 → S13 (McCarthy grounds graph-is-the-memory) */}
          <line x1="80"  y1="270" x2="350" y2="240" class="edge edge-derives" />
          {/* C11 → S13 (Anthropic memory tool grounds graph-is-the-memory) */}
          <line x1="95"  y1="130" x2="350" y2="240" class="edge edge-derives" />

          {/* citation grounds (solid) — edge to nearest synthesis */}
          {/* C06 → S01 */}
          <line x1="350" y1="30"  x2="350" y2="100" class="edge" />
          {/* C09 → S02 */}
          <line x1="605" y1="130" x2="483" y2="196" class="edge" />
          {/* C04 → S03 */}
          <line x1="620" y1="270" x2="432" y2="354" class="edge" />
          {/* C05 → S03 */}
          <line x1="555" y1="415" x2="432" y2="354" class="edge" />
          {/* C10 → S07 */}
          <line x1="145" y1="415" x2="268" y2="354" class="edge" />

          {nodes.map((n) => {
            const p = positions[n.id];
            if (!p) return null;
            return (
              <GraphNode
                type={n.type}
                cx={p.cx}
                cy={p.cy}
                r={p.r}
                isSpine={n.id === 'S13-graph-is-the-memory'}
                id={n.id}
                claim={n.claim}
                why={n.why}
                where={n.where}
                label={p.labelText}
                letter={typeMeta[n.type].letter}
                typeLabel={typeMeta[n.type].label}
                labelY={p.labelY}
              />
            );
          })}
        </svg>
        <div id="viz-tooltip" class="viz-tooltip" aria-hidden="true"></div>
      </div>

      <div class="dash-counts">
        {(Object.keys(counts) as NodeType[]).map((t) => (
          <span class={`chip ${typeMeta[t].chip}`}>
            {typeMeta[t].letter}
            <span class="chip-count"> {counts[t]}</span>
          </span>
        ))}
      </div>

      <div class="graph-nodes">
        {nodes.map((n) => (
          <article class={`graph-node graph-node-${n.type}`} id={n.id}>
            <p class="graph-node-head">
              <span class={`chip ${typeMeta[n.type].chip}`}>{typeMeta[n.type].letter}</span>
              <code class="graph-node-id">{n.id}</code>
              {n.where && <span class="graph-node-where">· {n.where}</span>}
            </p>
            <p class="graph-node-claim">{n.claim}</p>
            {n.source && (
              <p class="graph-node-source">
                <span class="graph-node-edge-label">grounds:</span>{' '}
                {n.url ? <a href={n.url} rel="noopener">{n.source}</a> : <span>{n.source}</span>}
              </p>
            )}
            {n.derives_from && n.derives_from.length > 0 && (
              <p class="graph-node-derives">
                <span class="graph-node-edge-label">derives_from:</span>{' '}
                {n.derives_from.map((d, i) => (
                  <>
                    {i > 0 && ', '}
                    <a href={`#${d}`}><code>{d}</code></a>
                  </>
                ))}
              </p>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="tab-eyes" class="tab-panel" role="tabpanel">
      <p class="tab-lead">Claims that need more grounding. The essay's confident synthesis — but where external corroboration would strengthen the case, or an open question is implicit.</p>

      <div class="eyes-list">
        {eyes.map((e) => (
          <article class="eyes-item">
            <p class="eyes-item-head">
              <a href={`#${e.id}`} class="eyes-item-id"><code>{e.id}</code></a>
            </p>
            <p class="eyes-what">{e.what}</p>
            <p class="eyes-why"><em>Why eyes:</em> {e.why}</p>
            {e.ground_with && e.ground_with.length > 0 && (
              <p class="eyes-ground">
                <span class="eyes-ground-label">ground_with:</span>
                <ul>
                  {e.ground_with.map((g) => (
                    <li>
                      {g.url ? <a href={g.url} rel="noopener">{g.label}</a> : <span>{g.label}</span>}
                    </li>
                  ))}
                </ul>
              </p>
            )}
            <p class="card-cta">
              <IssueLink kind="eyes" slug={slug} item={e} />
            </p>
          </article>
        ))}
      </div>
    </section>

    <section id="tab-actions" class="tab-panel" role="tabpanel">
      <p class="tab-lead">What the essay implies for the reader. Etudes drill specific claims; <em>apply</em> items put the principle to work; <em>next</em> points at sibling essays.</p>

      <div class="actions-list">
        {actions.map((a) => (
          <article class={`actions-item actions-item-${a.kind}`}>
            <p class="actions-item-head">
              <span class={`actions-kind actions-kind-${a.kind}`}>{a.kind}</span>
              {a.href ? (
                <a href={a.href} class="actions-item-label">{a.label} →</a>
              ) : (
                <span class="actions-item-label">{a.label}</span>
              )}
            </p>
            <p class="actions-item-body">{a.body}</p>
            {a.kind === 'apply' && (
              <p class="card-cta">
                <IssueLink kind="apply" slug={slug} item={a} />
              </p>
            )}
          </article>
        ))}
      </div>
    </section>
  </article>
</Base>

<script is:inline>
  document.querySelectorAll('.tabbar [data-tab]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const name = btn.getAttribute('data-tab');
      document.querySelectorAll('.tabbar [data-tab]').forEach((b) => {
        const active = b.getAttribute('data-tab') === name;
        b.classList.toggle('active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      document.querySelectorAll('.tab-panel').forEach((p) => {
        p.classList.toggle('active', p.id === 'tab-' + name);
      });
    });
  });

  // Deep-link via hash: #tab-eyes / #tab-actions / #tab-graph
  const hash = window.location.hash.replace('#', '');
  if (hash.startsWith('tab-')) {
    const name = hash.slice(4);
    const btn = document.querySelector(`.tabbar [data-tab="${name}"]`);
    if (btn) btn.click();
  }
  // Node click in viz → switch back to graph tab if needed, then anchor handles it
  document.querySelectorAll('.viz-node-link').forEach((a) => {
    a.addEventListener('click', () => {
      const graphBtn = document.querySelector('.tabbar [data-tab="graph"]');
      if (graphBtn && !graphBtn.classList.contains('active')) graphBtn.click();
    });
  });

  // Hover tooltip on graph nodes — pattern from /example-graph-full.html
  const tip = document.getElementById('viz-tooltip');
  if (tip) {
    const escape = (s) => String(s || '').replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[c]));

    document.querySelectorAll('.viz-node-link').forEach((a) => {
      a.addEventListener('mouseenter', () => {
        const id = a.getAttribute('data-id');
        const claim = a.getAttribute('data-claim');
        const why = a.getAttribute('data-why');
        const type = a.getAttribute('data-type');
        const where = a.getAttribute('data-where');
        let html = '<div class="vt-type">' + escape(type);
        if (where) html += '<span class="vt-dot">·</span>' + escape(where);
        html += '</div>';
        html += '<div class="vt-id"><code>' + escape(id) + '</code></div>';
        html += '<div class="vt-claim">' + escape(claim) + '</div>';
        if (why) html += '<div class="vt-why"><span class="vt-label">Why this node:</span> ' + escape(why) + '</div>';
        tip.innerHTML = html;
        tip.classList.add('visible');
      });
      a.addEventListener('mouseleave', () => tip.classList.remove('visible'));
      a.addEventListener('mousemove', (e) => {
        const pad = 12;
        const margin = 6;
        const w = tip.offsetWidth || 280;
        const h = tip.offsetHeight || 100;
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        let x = e.clientX + pad;
        if (x + w > vw - margin) x = e.clientX - w - pad;
        if (x < margin) x = margin;
        if (x + w > vw - margin) x = vw - w - margin;
        let y = e.clientY + pad;
        if (y + h > vh - margin) y = e.clientY - h - pad;
