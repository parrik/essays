---
/*
  Node detail drawer for essay-graph pages.

  Slides in from the right when any `.viz-node-link` is clicked, on
  desktop AND mobile. Replaces the previous behavior where clicking a
  node jumped the page to the matching card section below — that jump
  was disorienting because it scrolled away from the graph the reader
  was looking at.

  Desktop hover-tooltip behavior is left untouched (registered in each
  page's own script block).
*/
---
<aside id="viz-drawer" class="viz-drawer" aria-hidden="true">
  <div class="viz-drawer-backdrop" data-drawer-close></div>
  <div class="viz-drawer-panel" role="dialog" aria-modal="false" aria-labelledby="viz-drawer-title">
    <header class="viz-drawer-head">
      <p class="viz-drawer-type" id="viz-drawer-type"></p>
      <button type="button" class="viz-drawer-close" data-drawer-close aria-label="Close">×</button>
    </header>
    <code class="viz-drawer-id" id="viz-drawer-id"></code>
    <h3 class="viz-drawer-claim" id="viz-drawer-title"></h3>
    <p class="viz-drawer-why" id="viz-drawer-why" hidden></p>
    <a class="viz-drawer-jump" id="viz-drawer-jump" href="#">Open this node's card →</a>
  </div>
</aside>

<script is:inline>
  (function () {
    const drawer = document.getElementById('viz-drawer');
    if (!drawer) return;

    const dType = document.getElementById('viz-drawer-type');
    const dId = document.getElementById('viz-drawer-id');
    const dClaim = document.getElementById('viz-drawer-title');
    const dWhy = document.getElementById('viz-drawer-why');
    const dJump = document.getElementById('viz-drawer-jump');

    const open = (anchor) => {
      const id = anchor.getAttribute('data-id') || '';
      const claim = anchor.getAttribute('data-claim') || '';
      const why = anchor.getAttribute('data-why') || '';
      const type = anchor.getAttribute('data-type') || '';
      const where = anchor.getAttribute('data-where') || '';
      dType.textContent = where ? type + ' · ' + where : type;
      dId.textContent = id;
      dClaim.textContent = claim;
      if (why) {
        dWhy.textContent = 'Why this node: ' + why;
        dWhy.hidden = false;
      } else {
        dWhy.hidden = true;
      }
      dJump.setAttribute('href', '#' + id);
      drawer.setAttribute('aria-hidden', 'false');
    };
    const close = () => {
      drawer.setAttribute('aria-hidden', 'true');
    };

    // Click any node in the SVG → open the drawer (do NOT jump to anchor).
    document.querySelectorAll('.viz-node-link').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        open(a);
      });
    });
    drawer.querySelectorAll('[data-drawer-close]').forEach((el) => {
      el.addEventListener('click', close);
    });
    // Jump-to-card from inside the drawer: close, then let the anchor jump.
    dJump.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') close();
    });
    // Click anywhere outside the drawer panel closes it — except clicks
    // on a graph node, which swap the drawer content in place.
    document.addEventListener('click', (e) => {
      if (drawer.getAttribute('aria-hidden') !== 'false') return;
      const t = e.target;
      if (!(t instanceof Element)) return;
      if (t.closest('.viz-drawer-panel')) return;
      if (t.closest('.viz-node-link')) return;
      close();
    });
  })();
</script>

<style is:global>
  .viz-drawer {
    position: fixed;
    inset: 0;
    z-index: 1000;
    pointer-events: none;
  }
  .viz-drawer[aria-hidden="false"] {
    pointer-events: auto;
  }
  /* Backdrop: hidden on desktop (drawer is non-modal — keep clicking
     other nodes to swap content). Shown on small screens where the
     panel covers most of the viewport and a tap-outside dismiss is
     more useful than visible graph behind. */
  .viz-drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(40, 30, 20, 0.4);
    opacity: 0;
    transition: opacity 200ms ease;
    pointer-events: none;
  }
  @media (max-width: 32rem) {
    .viz-drawer[aria-hidden="false"] .viz-drawer-backdrop {
      opacity: 1;
      pointer-events: auto;
    }
  }
  .viz-drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(420px, 100%);
    overflow-y: auto;
    background: #fffdf7;
    border-left: 1px solid var(--line);
    padding: 1.25rem 1.35rem 1.5rem;
    box-shadow: -8px 0 24px rgba(40, 30, 20, 0.12);
    transform: translateX(100%);
    transition: transform 240ms cubic-bezier(0.32, 0.72, 0, 1);
    box-sizing: border-box;
  }
  .viz-drawer[aria-hidden="false"] .viz-drawer-panel { transform: translateX(0); }
  .viz-drawer-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0 0 0.5rem;
  }
  .viz-drawer-type {
    margin: 0;
    font-family: var(--sans);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .viz-drawer-close {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--muted);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    /* 44px touch target — Apple HIG floor */
    min-height: 44px;
    min-width: 44px;
  }
  .viz-drawer-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
  .viz-drawer-id {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    color: var(--muted);
    background: transparent;
    padding: 0;
    margin: 0 0 0.5rem;
  }
  .viz-drawer-claim {
    margin: 0 0 0.6rem;
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--text);
    font-weight: 500;
  }
  .viz-drawer-why {
    margin: 0 0 1rem;
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.5;
    color: #4a4238;
  }
  .viz-drawer-jump {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--accent);
    text-decoration: none;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 500;
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease;
  }
  .viz-drawer-jump:hover {
    border-bottom-color: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .viz-drawer-panel,
    .viz-drawer-backdrop {
      transition: none;
    }
  }
</style>
