---
/*
  Mobile node drawer for essay-graph pages.

  On touch devices (no hover capability), tapping a graph SVG node opens
  this bottom-sheet drawer instead of jumping the page to the node card
  below. Desktop hover-tooltip behavior is preserved — the script only
  binds when `matchMedia('(hover: none)')` matches.

  Drop into any page that renders `.viz-node-link` anchors.
*/
---
<aside id="viz-drawer" class="viz-drawer" aria-hidden="true">
  <div class="viz-drawer-backdrop" data-drawer-close></div>
  <div class="viz-drawer-panel" role="dialog" aria-modal="true" aria-labelledby="viz-drawer-title">
    <header class="viz-drawer-head">
      <p class="viz-drawer-type" id="viz-drawer-type"></p>
      <button type="button" class="viz-drawer-close" data-drawer-close aria-label="Close">×</button>
    </header>
    <code class="viz-drawer-id" id="viz-drawer-id"></code>
    <h3 class="viz-drawer-claim" id="viz-drawer-title"></h3>
    <p class="viz-drawer-why" id="viz-drawer-why" hidden></p>
    <a class="viz-drawer-jump" id="viz-drawer-jump" href="#">Open this node's card →</a>
  </div>
</aside>

<script is:inline>
  (function () {
    const noHover = typeof matchMedia === 'function' && matchMedia('(hover: none)').matches;
    const drawer = document.getElementById('viz-drawer');
    if (!noHover || !drawer) return;

    const dType = document.getElementById('viz-drawer-type');
    const dId = document.getElementById('viz-drawer-id');
    const dClaim = document.getElementById('viz-drawer-title');
    const dWhy = document.getElementById('viz-drawer-why');
    const dJump = document.getElementById('viz-drawer-jump');

    const open = (anchor) => {
      const id = anchor.getAttribute('data-id') || '';
      const claim = anchor.getAttribute('data-claim') || '';
      const why = anchor.getAttribute('data-why') || '';
      const type = anchor.getAttribute('data-type') || '';
      const where = anchor.getAttribute('data-where') || '';
      dType.textContent = where ? type + ' · ' + where : type;
      dId.textContent = id;
      dClaim.textContent = claim;
      if (why) {
        dWhy.textContent = 'Why this node: ' + why;
        dWhy.hidden = false;
      } else {
        dWhy.hidden = true;
      }
      dJump.setAttribute('href', '#' + id);
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    document.querySelectorAll('.viz-node-link').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        open(a);
      });
    });
    drawer.querySelectorAll('[data-drawer-close]').forEach((el) => {
      el.addEventListener('click', close);
    });
    // Jump-to-card closes the drawer; default href anchor jump still fires.
    dJump.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') close();
    });
  })();
</script>

<style is:global>
  .viz-drawer {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
  }
  .viz-drawer[aria-hidden="false"] {
    display: block;
  }
  .viz-drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(40, 30, 20, 0.4);
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .viz-drawer[aria-hidden="false"] .viz-drawer-backdrop { opacity: 1; }
  .viz-drawer-panel {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    max-height: 85vh;
    overflow-y: auto;
    background: #fffdf7;
    border-radius: 16px 16px 0 0;
    padding: 1rem 1.15rem 1.5rem;
    box-shadow: 0 -8px 24px rgba(40, 30, 20, 0.16);
    transform: translateY(100%);
    transition: transform 220ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .viz-drawer[aria-hidden="false"] .viz-drawer-panel { transform: translateY(0); }
  .viz-drawer-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0 0 0.5rem;
  }
  .viz-drawer-type {
    margin: 0;
    font-family: var(--sans);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .viz-drawer-close {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--muted);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    /* 44px touch target — Apple HIG floor */
    min-height: 44px;
    min-width: 44px;
  }
  .viz-drawer-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
  .viz-drawer-id {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    color: var(--muted);
    background: transparent;
    padding: 0;
    margin: 0 0 0.5rem;
  }
  .viz-drawer-claim {
    margin: 0 0 0.6rem;
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--text);
    font-weight: 500;
  }
  .viz-drawer-why {
    margin: 0 0 1rem;
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.5;
    color: #4a4238;
  }
  .viz-drawer-jump {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--accent);
    text-decoration: none;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 500;
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease;
  }
  .viz-drawer-jump:hover {
    border-bottom-color: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .viz-drawer-panel,
    .viz-drawer-backdrop {
      transition: none;
    }
  }
</style>
